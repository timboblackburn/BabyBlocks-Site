---
import '../styles/theme.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonical?: string;
}

const {
  title,
  description = 'BabyBlocks: simple, visual iOS apps for a calmer life. BudgetBaby helps you stay in control of your money without the stress.',
  ogTitle,
  ogDescription,
  canonical,
} = Astro.props;

const pageTitle = title.includes('BabyBlocks') ? title : `${title} | BabyBlocks`;
const ogT = ogTitle ?? pageTitle;
const ogD = ogDescription ?? description;
const siteURL = 'https://babyblocks.io';
const canonicalURL = canonical ? `${siteURL}${canonical}` : siteURL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogT} />
    <meta property="og:description" content={ogD} />
    <meta property="og:site_name" content="BabyBlocks" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogT} />
    <meta name="twitter:description" content={ogD} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preconnect -->
    <link rel="dns-prefetch" href="https://babyblocks.canny.io" />

    <!-- Theme -->
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#09090F" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content" class="page-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
