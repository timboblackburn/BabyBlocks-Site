---
import Layout from './Layout.astro';
import Icon from '../components/Icon.astro';
import { docsNav } from '../data/docsNav';

interface Heading {
  id: string;
  text: string;
  depth?: number; // 1 = section (h2), 2 = sub-item (h3)
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  headings?: Heading[];
}

const { title, description, canonical, headings = [] } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '');
const hasHeadings = headings.length > 0;

function isActive(href: string): boolean {
  return pathname === href.replace(/\/$/, '');
}
---

<Layout title={title} description={description} canonical={canonical}>
  <!-- Mobile overlay -->
  <div class="docs-overlay" id="docs-overlay" aria-hidden="true"></div>

  <div class:list={['docs-shell', { 'has-toc': hasHeadings }]}>
    <!-- Sidebar -->
    <aside class="docs-sidebar" id="docs-sidebar" aria-label="Documentation navigation">
      <div class="docs-sidebar-inner">
        <div class="docs-sidebar-header">
          <a href="/budgetbaby" class="docs-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            BudgetBaby
          </a>
          <a href="/budgetbaby/docs" class:list={['docs-home-link', { active: isActive('/budgetbaby/docs') }]}>
            Documentation
          </a>
        </div>

        <nav aria-label="Documentation sections">
          {docsNav.map(group => (
            <div class="docs-nav-group">
              <p class="docs-nav-group-label">{group.group}</p>
              <ul class="docs-nav-list">
                {group.items.map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={['docs-nav-link', { active: isActive(item.href) }]}
                      aria-current={isActive(item.href) ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>

        <div class="docs-sidebar-footer">
          <p>Can't find what you need?</p>
          <a href="/budgetbaby/support">Contact Support</a>
        </div>
      </div>
    </aside>

    <!-- Main content -->
    <main class="docs-main">
      <!-- Mobile nav toggle -->
      <button class="docs-mobile-toggle" id="docs-sidebar-toggle" aria-label="Open navigation" aria-expanded="false" aria-controls="docs-sidebar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        Menu
      </button>

      <!-- Breadcrumb -->
      <nav class="docs-breadcrumb" aria-label="Breadcrumb">
        <a href="/budgetbaby">BudgetBaby</a>
        <span aria-hidden="true">/</span>
        <a href="/budgetbaby/docs">Docs</a>
        {!isActive('/budgetbaby/docs') && (
          <>
            <span aria-hidden="true">/</span>
            <span aria-current="page">{title}</span>
          </>
        )}
      </nav>

      <!-- Page content -->
      <div class="docs-content">
        <slot />
      </div>

      <!-- Still stuck callout -->
      <div class="docs-stuck">
        <div class="docs-stuck-inner">
          <Icon name="mail" size={18} />
          <div class="docs-stuck-text">
            <strong>Still stuck?</strong>
            <p>Email <a href="mailto:support@babyblocks.io">support@babyblocks.io</a> with your iOS version, app version (Settings → About), and a brief description of the issue. We reply within 1-2 business days.</p>
          </div>
          <a href="/budgetbaby/support" class="btn btn-secondary docs-stuck-btn">Get help</a>
        </div>
      </div>
    </main>

    <!-- On this page TOC -->
    {hasHeadings && (
      <aside class="docs-toc" aria-label="On this page">
        <p class="docs-toc-label">On this page</p>
        <ul class="docs-toc-list" id="docs-toc-list">
          {headings.map(h => (
            <li>
              <a
                href={`#${h.id}`}
                class:list={['docs-toc-link', { 'docs-toc-sub': h.depth && h.depth > 1 }]}
              >{h.text}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </div>
</Layout>

<script>
  // Mobile sidebar toggle
  const toggle = document.getElementById('docs-sidebar-toggle');
  const sidebar = document.getElementById('docs-sidebar');
  const overlay = document.getElementById('docs-overlay');

  function openSidebar() {
    sidebar?.classList.add('is-open');
    overlay?.classList.add('is-visible');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close navigation');
  }

  function closeSidebar() {
    sidebar?.classList.remove('is-open');
    overlay?.classList.remove('is-visible');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open navigation');
  }

  toggle?.addEventListener('click', () => {
    if (sidebar?.classList.contains('is-open')) {
      closeSidebar();
    } else {
      openSidebar();
    }
  });

  overlay?.addEventListener('click', closeSidebar);

  // Close sidebar on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sidebar?.classList.contains('is-open')) {
      closeSidebar();
    }
  });

  // TOC scroll-spy
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.docs-toc-link');
  if (tocLinks.length > 0) {
    const headings = Array.from(
      document.querySelectorAll<HTMLElement>('.docs-content h2[id], .docs-content h3[id]')
    );

    let activeId = '';

    const setActive = (id: string) => {
      if (id === activeId) return;
      activeId = id;
      tocLinks.forEach(link => {
        link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
      });
    };

    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        });
      },
      { rootMargin: '-80px 0px -55% 0px', threshold: 0 }
    );

    headings.forEach(h => observer.observe(h));
  }
</script>

<style>
  /* ── Shell layout ── */
  .docs-shell {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: calc(100dvh - var(--nav-height));
    max-width: var(--max-w-xl);
    margin-inline: auto;
    padding-inline: var(--space-5);
    gap: var(--space-12);
    padding-top: var(--space-10);
    padding-bottom: var(--space-16);
    align-items: start;
  }

  .docs-shell.has-toc {
    grid-template-columns: 260px 1fr 220px;
  }

  /* ── Overlay ── */
  .docs-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 49;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .docs-overlay.is-visible {
    opacity: 1;
  }

  /* ── Sidebar ── */
  .docs-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-4));
    max-height: calc(100dvh - var(--nav-height) - var(--space-8));
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--glass-border) transparent;
  }

  .docs-sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .docs-sidebar-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--glass-border);
  }

  .docs-back {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .docs-back:hover { color: var(--text-secondary); }

  .docs-home-link {
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .docs-home-link.active { color: var(--accent-light); }

  /* ── Sidebar nav ── */
  .docs-nav-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .docs-nav-group-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    padding: var(--space-2) var(--space-3);
    margin: 0;
  }

  .docs-nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .docs-nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background 0.12s, color 0.12s;
    line-height: var(--leading-snug);
  }

  .docs-nav-link:hover {
    background: var(--glass-bg);
    color: var(--text-primary);
  }

  .docs-nav-link.active {
    background: var(--accent-dim);
    color: var(--accent-light);
    font-weight: var(--weight-medium);
  }

  /* ── Sidebar footer ── */
  .docs-sidebar-footer {
    padding-top: var(--space-4);
    border-top: 1px solid var(--glass-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .docs-sidebar-footer p {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  .docs-sidebar-footer a {
    font-size: var(--text-xs);
    color: var(--accent-light);
    text-decoration: none;
    font-weight: var(--weight-medium);
  }
  .docs-sidebar-footer a:hover { text-decoration: underline; }

  /* ── Mobile toggle ── */
  .docs-mobile-toggle {
    display: none;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    cursor: pointer;
    margin-bottom: var(--space-6);
    width: fit-content;
  }

  /* ── Breadcrumb ── */
  .docs-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }

  .docs-breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .docs-breadcrumb a:hover { color: var(--text-secondary); }

  .docs-breadcrumb span[aria-current] {
    color: var(--text-secondary);
  }

  /* ── Main ── */
  .docs-main {
    min-width: 0;
  }

  /* ── Content: styles for slotted content ── */
  :global(.docs-content h1) {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }

  :global(.docs-content .docs-summary) {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 58ch;
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--glass-border);
  }

  :global(.docs-content h2) {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--glass-border);
    scroll-margin-top: calc(var(--nav-height) + var(--space-8));
  }

  :global(.docs-content h3) {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    scroll-margin-top: calc(var(--nav-height) + var(--space-8));
  }

  :global(.docs-content h4) {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-secondary);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
    letter-spacing: 0.01em;
  }

  :global(.docs-content p) {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  :global(.docs-content p:last-child) { margin-bottom: 0; }

  :global(.docs-content a) {
    color: var(--accent-light);
    text-decoration: none;
  }
  :global(.docs-content a:hover) { text-decoration: underline; }

  :global(.docs-content ul, .docs-content ol) {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  :global(.docs-content ul) { list-style: disc; }
  :global(.docs-content ol) { list-style: decimal; }

  :global(.docs-content strong) { color: var(--text-primary); font-weight: var(--weight-semibold); }
  :global(.docs-content em) { font-style: italic; }

  :global(.docs-content code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 4px;
    padding: 1px 5px;
    color: var(--purple-300, var(--accent-light));
  }

  /* Doc-specific components */
  :global(.doc-tip) {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-left: 3px solid var(--accent-light);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-block: var(--space-5);
  }

  :global(.doc-tip strong) { color: var(--accent-light); }

  :global(.doc-warning) {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-left: 3px solid #F97316;
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-block: var(--space-5);
  }

  :global(.doc-formula) {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin-block: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--purple-300, var(--accent-light));
    overflow-x: auto;
  }

  :global(.doc-status-list) { list-style: none; padding-left: 0; }
  :global(.doc-status-list li) { display: flex; align-items: center; gap: var(--space-2); }
  :global(.status-dot) { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  :global(.status-dot.green)  { background: var(--green); }
  :global(.status-dot.yellow) { background: var(--yellow); }
  :global(.status-dot.orange) { background: #F97316; }
  :global(.status-dot.red)    { background: var(--red); }
  :global(.status-dot.muted)  { background: var(--text-muted); }

  :global(.doc-badge-premium) {
    display: inline-flex;
    align-items: center;
    font-size: 10px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-light);
    background: var(--accent-dim);
    border: 1px solid var(--accent-muted, var(--glass-border));
    border-radius: 4px;
    padding: 1px 6px;
    vertical-align: middle;
    margin-left: var(--space-2);
  }

  :global(.doc-badge-soon) {
    display: inline-flex;
    align-items: center;
    font-size: 10px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 4px;
    padding: 1px 6px;
    vertical-align: middle;
    margin-left: var(--space-2);
  }

  /* Table styles */
  :global(.docs-content table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-block: var(--space-6);
  }

  :global(.docs-content th) {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--glass-border);
    background: var(--glass-bg);
  }

  :global(.docs-content td) {
    padding: var(--space-3) var(--space-4);
    color: var(--text-secondary);
    border-bottom: 1px solid var(--glass-border);
    line-height: var(--leading-relaxed);
    vertical-align: top;
  }

  :global(.docs-content tr:last-child td) { border-bottom: none; }

  :global(.docs-content .table-wrap) {
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    overflow-x: auto;
    margin-block: var(--space-6);
  }

  :global(.docs-content .table-wrap table) { margin: 0; }

  /* Common tasks block */
  :global(.docs-quick-tasks) {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5) var(--space-6);
    margin-bottom: var(--space-10);
  }

  :global(.docs-quick-label) {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }

  :global(.docs-quick-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2);
  }

  :global(.docs-quick-item) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    border: 1px solid transparent;
  }

  :global(.docs-quick-item svg) { color: var(--accent-light); flex-shrink: 0; }

  :global(.docs-quick-item:hover) {
    background: var(--glass-bg-hover, var(--glass-bg));
    color: var(--text-primary);
    border-color: var(--glass-border);
  }

  /* Next steps block */
  :global(.docs-next-steps) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  :global(.docs-next-item) {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  :global(.docs-next-item:hover) {
    border-color: var(--accent-light);
    background: var(--accent-dim);
  }

  :global(.docs-next-item strong) {
    font-size: var(--text-sm);
    color: var(--text-primary);
  }

  :global(.docs-next-item span) {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* ── Still stuck ── */
  .docs-stuck {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--glass-border);
  }

  .docs-stuck-inner {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5) var(--space-6);
  }

  .docs-stuck-inner svg { color: var(--accent-light); flex-shrink: 0; margin-top: 2px; }

  .docs-stuck-text {
    flex: 1;
  }

  .docs-stuck-text strong {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
    display: block;
    margin-bottom: var(--space-1);
  }

  .docs-stuck-text p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .docs-stuck-text a {
    color: var(--accent-light);
    text-decoration: none;
  }
  .docs-stuck-text a:hover { text-decoration: underline; }

  .docs-stuck-btn { flex-shrink: 0; align-self: center; }

  /* ── TOC ── */
  .docs-toc {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-4));
    max-height: calc(100dvh - var(--nav-height) - var(--space-8));
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--glass-border) transparent;
  }

  .docs-toc-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: var(--space-3);
    padding: 0;
  }

  .docs-toc-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 1px solid var(--glass-border);
    padding-left: var(--space-3);
  }

  .docs-toc-link {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    padding: 3px var(--space-2);
    border-radius: 3px;
    line-height: var(--leading-snug);
    transition: color 0.12s;
  }

