---
const navLinks = [
  {
    label: 'BudgetBaby',
    href: '/budgetbaby',
    sub: [
      { label: 'Overview', href: '/budgetbaby' },
      { label: 'Features', href: '/budgetbaby/features' },
      { label: 'Documentation', href: '/budgetbaby/documentation' },
      { label: 'Support', href: '/budgetbaby/support' },
    ],
  },
  {
    label: 'Coming Soon',
    href: '/coming-soon',
    sub: [
      { label: 'PantryBaby 🥗', href: '/coming-soon/pantrybaby' },
      { label: 'BabyBlocks Core 🧩', href: '/coming-soon/babyblocks-core' },
      { label: 'Roadmap 🗺️', href: '/coming-soon/roadmap' },
    ],
  },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner container">
    <a href="/" class="logo" aria-label="BabyBlocks home">
      <span class="logo-icon" aria-hidden="true">🧩</span>
      <span class="logo-text">BabyBlocks</span>
    </a>

    <nav class="primary-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li class={`nav-item ${link.sub ? 'has-dropdown' : ''}`}>
            {link.sub ? (
              <button
                class={`nav-link nav-link-btn ${currentPath.startsWith(link.href) ? 'active' : ''}`}
                aria-haspopup="true"
                aria-expanded="false"
              >
                {link.label}
                <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <ul class="dropdown" role="menu">
                {link.sub.map((sub) => (
                  <li role="none">
                    <a
                      href={sub.href}
                      class={`dropdown-link ${currentPath === sub.href ? 'active' : ''}`}
                      role="menuitem"
                    >
                      {sub.label}
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <a
                href={link.href}
                class={`nav-link ${currentPath === link.href ? 'active' : ''}`}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-cta">
      <a href="/budgetbaby" class="btn btn-primary" aria-label="Get BudgetBaby">
        Get the App
      </a>
    </div>

    <button class="mobile-menu-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="mobile-nav">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation" hidden>
    <div class="mobile-nav-inner">
      <ul class="mobile-nav-list">
        <li><a href="/budgetbaby" class="mobile-nav-link">BudgetBaby</a></li>
        <li><a href="/budgetbaby/features" class="mobile-nav-link mobile-sub">Features</a></li>
        <li><a href="/budgetbaby/documentation" class="mobile-nav-link mobile-sub">Documentation</a></li>
        <li><a href="/budgetbaby/support" class="mobile-nav-link mobile-sub">Support</a></li>
        <li><a href="/coming-soon" class="mobile-nav-link">Coming Soon</a></li>
        <li><a href="/coming-soon/pantrybaby" class="mobile-nav-link mobile-sub">PantryBaby 🥗</a></li>
        <li><a href="/coming-soon/babyblocks-core" class="mobile-nav-link mobile-sub">BabyBlocks Core 🧩</a></li>
        <li><a href="/coming-soon/roadmap" class="mobile-nav-link mobile-sub">Roadmap 🗺️</a></li>
        <li><a href="/about" class="mobile-nav-link">About</a></li>
        <li class="mobile-cta">
          <a href="/budgetbaby" class="btn btn-primary" style="width:100%; justify-content:center;">
            Get the App
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--header-bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--header-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: var(--nav-height);
    gap: var(--space-8);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon { font-size: 1.4rem; line-height: 1; }

  .logo-text {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .primary-nav { flex: 1; }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
  }

  .nav-item {
    position: relative;
  }

  .nav-link, .nav-link-btn {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.15s ease;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    white-space: nowrap;
  }

  .nav-link:hover, .nav-link-btn:hover {
    color: var(--text-primary);
    background: var(--glass-bg);
  }

  .nav-link.active, .nav-link-btn.active {
    color: var(--accent-light);
  }

  /* Dropdown */
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    background: var(--bg-elevated);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2);
    list-style: none;
    min-width: 180px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.15s ease;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: var(--shadow-lg);
    z-index: 10;
  }

  .dropdown-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.12s ease;
    white-space: nowrap;
  }

  .dropdown-link:hover {
    color: var(--text-primary);
    background: var(--glass-bg-hover);
  }

  .dropdown-link.active { color: var(--accent-light); }

  /* CTA */
  .header-cta { margin-left: auto; flex-shrink: 0; }

  /* Mobile toggle */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .bar {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: all 0.2s ease;
  }

  .mobile-menu-toggle[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .mobile-menu-toggle[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-toggle[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile nav */
  .mobile-nav {
    border-top: 1px solid var(--header-border);
    background: var(--mobile-nav-bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  .mobile-nav[hidden] { display: none; }

  .mobile-nav-inner {
    padding: var(--space-4) var(--space-5) var(--space-6);
  }

  .mobile-nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .mobile-nav-link {
    display: block;
    padding: var(--space-3) var(--space-3);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .mobile-nav-link.mobile-sub {
    font-size: var(--text-sm);
    color: var(--text-muted);
    padding-left: var(--space-6);
  }

  .mobile-nav-link:hover, .mobile-nav-link.mobile-sub:hover {
    color: var(--text-primary);
    background: var(--glass-bg);
  }

  .mobile-cta { margin-top: var(--space-4); padding: 0 var(--space-3); }

  @media (max-width: 768px) {
    .primary-nav, .header-cta { display: none; }
    .mobile-menu-toggle { display: flex; }
    .header-inner { gap: var(--space-4); }
  }
</style>

<script>
  // Mobile menu toggle
  const toggle = document.querySelector('.mobile-menu-toggle') as HTMLButtonElement;
  const nav = document.getElementById('mobile-nav');

  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.hidden = expanded;
    });
  }
</script>
