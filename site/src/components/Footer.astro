---
import Icon from './Icon.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <Icon name="layers" size={20} />
          <span>BabyBlocks</span>
        </a>
        <p class="footer-tagline">
          Simple, visual apps for a calmer life.<br />
          Built by Intriguing Insight.
        </p>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <h3 class="footer-col-title">BudgetBaby</h3>
          <ul class="footer-links">
            <li><a href="/budgetbaby">Overview</a></li>
            <li><a href="/budgetbaby/features">Features</a></li>
            <li><a href="/budgetbaby/documentation">Documentation</a></li>
            <li><a href="/budgetbaby/support">Support</a></li>
            <li><a href="/budgetbaby/trust">Trust &amp; Privacy</a></li>
            <li><a href="/budgetbaby/privacy">Privacy Policy</a></li>
            <li><a href="/budgetbaby/terms">Terms of Use</a></li>
            <li><a href="/budgetbaby/delete-data">Delete Your Data</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3 class="footer-col-title">Ecosystem</h3>
          <ul class="footer-links">
            <li><a href="/coming-soon">Coming Soon</a></li>
            <li><a href="/coming-soon/roadmap">Roadmap</a></li>
            <li><a href="/changelog">Changelog</a></li>
            <li><a href="/status">Status</a></li>
            <li><a href="/security">Security</a></li>
            <li><a href="/about">About BabyBlocks</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3 class="footer-col-title">Contact</h3>
          <ul class="footer-links">
            <li><a href="mailto:support@babyblocks.io">support@babyblocks.io</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p class="footer-legal">
        &copy; {year} Intrigue MMC LLC · All rights reserved.
      </p>
      <div class="footer-legal-links">
        <a href="/budgetbaby/privacy">Privacy</a>
        <span aria-hidden="true">·</span>
        <a href="/budgetbaby/terms">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--glass-border);
    background: var(--bg-raised);
    margin-top: var(--space-24);
  }

  .footer-inner { padding-block: var(--space-16) var(--space-8); }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-16);
    margin-bottom: var(--space-12);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }

  .footer-tagline {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .footer-col-title {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-links a {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-links a:hover { color: var(--text-primary); }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-6);
    border-top: 1px solid var(--glass-border);
    gap: var(--space-4);
  }

  .footer-legal, .footer-legal-links {
    font-size: var(--text-xs);
    color: var(--text-faint);
  }

  .footer-legal-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-legal-links a {
    color: var(--text-faint);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-legal-links a:hover { color: var(--text-muted); }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8) var(--space-6);
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
  }

  @media (max-width: 480px) {
    .footer-nav { grid-template-columns: 1fr; }
  }
</style>
