---
interface Props {
  heading?: string;
  subheading?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  heading = 'Take control of your finances.',
  subheading = 'Download BudgetBaby and know exactly where your money goes. Start today.',
  primaryLabel = 'Download on the App Store',
  primaryHref = '#app-store',
  secondaryLabel = 'See all features',
  secondaryHref = '/budgetbaby/features',
} = Astro.props;
---

<section class="cta-section section-sm">
  <div class="container">
    <div class="cta-card glass-accent">
      <div class="cta-glow" aria-hidden="true"></div>
      <div class="cta-content">
        <h2>{heading}</h2>
        <p>{subheading}</p>
        <div class="cta-actions">
          <a href={primaryHref} class="btn btn-primary btn-lg">
            {primaryLabel}
          </a>
          {secondaryLabel && (
            <a href={secondaryHref} class="btn btn-secondary btn-lg">
              {secondaryLabel}
            </a>
          )}
        </div>
        <p class="cta-note">Free to download · iOS 17+ required · Premium from $4.99/mo</p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section { padding-block: var(--space-16); }

  .cta-card {
    position: relative;
    overflow: hidden;
    padding: var(--space-16) var(--space-12);
    text-align: center;
    border-radius: var(--radius-2xl);
  }

  .cta-glow {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, var(--cta-glow-color) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  .cta-content h2 {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    margin-bottom: var(--space-4);
  }

  .cta-content p {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 48ch;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .cta-note {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .cta-card { padding: var(--space-10) var(--space-6); }
    .cta-actions { flex-direction: column; align-items: stretch; }
    .cta-actions .btn { text-align: center; }
  }
</style>
