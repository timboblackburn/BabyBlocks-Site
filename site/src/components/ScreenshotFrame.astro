---
interface Props {
  caption: string;
  label?: string;
}
const { caption, label } = Astro.props;
---
<div class="screenshot-frame">
  {label && <div class="screenshot-label">{label}</div>}
  <div class="screenshot-device">
    <div class="screenshot-chrome">
      <div class="screenshot-notch"></div>
    </div>
    <div class="screenshot-screen">
      <slot />
    </div>
  </div>
  <p class="screenshot-caption">{caption}</p>
</div>

<style>
  .screenshot-frame {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .screenshot-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-light);
  }

  .screenshot-device {
    width: 200px;
    height: 420px;
    background: var(--bg-elevated);
    border-radius: 36px;
    border: 1.5px solid var(--glass-border);
    box-shadow:
      0 0 0 6px var(--bg-surface),
      0 0 0 7px var(--glass-border),
      0 28px 60px rgba(0, 0, 0, 0.45),
      0 0 40px rgba(139, 92, 246, 0.08);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .screenshot-chrome {
    height: 44px;
    background: var(--bg-raised);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--glass-border);
  }

  .screenshot-notch {
    width: 72px;
    height: 20px;
    background: var(--bg-elevated);
    border-radius: 12px;
  }

  .screenshot-screen {
    flex: 1;
    overflow: hidden;
    background: var(--bg-base);
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .screenshot-caption {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-align: center;
    max-width: 18ch;
    line-height: var(--leading-relaxed);
    margin: 0;
  }
</style>
