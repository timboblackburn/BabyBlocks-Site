---
import Layout from '../layouts/Layout.astro';
import GlassCard from '../components/GlassCard.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout
  title="Changelog — BudgetBaby"
  description="BudgetBaby version history. See what's new in every release."
  canonical="/changelog"
>
  <section class="changelog-hero section">
    <div class="container">
      <div class="changelog-hero-inner">
        <div class="label-chip">Changelog</div>
        <h1>What's new in <span class="text-gradient">BudgetBaby.</span></h1>
        <p>Every release, documented. We ship meaningful updates, not changelog padding.</p>
      </div>
    </div>
  </section>

  <section class="changelog-body section-sm">
    <div class="container-sm">

      <!-- v2.1.0 -->
      <div class="cl-entry">
        <div class="cl-meta">
          <span class="cl-version">v2.1.0</span>
          <span class="cl-date">March 2026</span>
          <span class="cl-badge new">New</span>
        </div>
        <GlassCard>
          <details class="cl-details" open>
            <summary class="cl-summary">
              <h2>Insights Drill-Downs, Receipt Attachments &amp; Reminders Overhaul</h2>
              <svg class="cl-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="cl-body">
              <div class="cl-group">
                <h3>Insights Drill-Downs</h3>
                <ul>
                  <li>Tap any period row in Spending Trends to see every transaction for that category and month, newest to oldest. Each transaction is tappable for full detail.</li>
                  <li><strong>Premium:</strong> Tap any month in Month History for a complete period analysis: budget stats card, category breakdown ranked by spend with fill bars, and all transactions with date headers.</li>
                </ul>
              </div>
              <div class="cl-group">
                <h3>Receipt Attachments</h3>
                <ul>
                  <li>Attach a photo receipt to any transaction from the activity log or transaction detail view.</li>
                  <li>Tap the thumbnail to view full-screen. Remove with one tap.</li>
                  <li>JPEG compressed at 70% quality for efficient on-device storage.</li>
                </ul>
              </div>
              <div class="cl-group">
                <h3>Reminders Overhaul (Premium)</h3>
                <ul>
                  <li>Per-subscription reminder schedules — set custom days-before per subscription, not just per bill.</li>
                  <li>Custom notification message text per bill and subscription.</li>
                  <li>Quiet hours: set a window (e.g. 10 PM – 8 AM) to suppress all reminders.</li>
                  <li>Monthly savings goal nudge: a mid-month reminder to fund your savings goals, on a day you choose.</li>
                </ul>
              </div>
            </div>
          </details>
        </GlassCard>
      </div>

      <!-- v2.0.4 -->
      <div class="cl-entry">
        <div class="cl-meta">
          <span class="cl-version">v2.0.4</span>
          <span class="cl-date">January 2026</span>
        </div>
        <GlassCard>
          <details class="cl-details">
            <summary class="cl-summary">
              <h2>Data Integrity Audit, Onboarding Simplification &amp; UI Polish</h2>
              <svg class="cl-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="cl-body">
              <div class="cl-group">
                <h3>Data Integrity</h3>
                <ul>
                  <li>Full audit of all save, delete, and cloud sync operations. Added rollback protection to the budget period rollover flow — the primary safeguard against a rare edge case that could cause the active budget to vanish.</li>
                  <li>Cloud sync now blocks rather than warns on entity count drops greater than 25% post-download.</li>
                  <li>Collapse detection now correctly identifies periods-exist-but-none-active as a collapse state.</li>
                  <li>Restore service now correctly syncs the data integrity baseline after an atomic restore.</li>
                </ul>
              </div>
              <div class="cl-group">
                <h3>Onboarding</h3>
                <ul>
                  <li>Simplified 8-step onboarding: removed redundant steps, tightened copy throughout.</li>
                  <li>USD set as the default currency for new installs.</li>
                  <li>TestFlight: premium features now available for testing without a subscription.</li>
                </ul>
              </div>
              <div class="cl-group">
                <h3>UI Polish</h3>
                <ul>
                  <li>Miscellaneous layout fixes across the transaction log, category detail, and settings screens.</li>
                  <li>Improved empty state handling in several list views.</li>
                  <li>Performance improvements for large transaction datasets.</li>
                </ul>
              </div>
            </div>
          </details>
        </GlassCard>
      </div>

      <!-- v2.0.0 -->
      <div class="cl-entry">
        <div class="cl-meta">
          <span class="cl-version">v2.0.0</span>
          <span class="cl-date">December 2024</span>
          <span class="cl-badge launch">Launch</span>
        </div>
        <GlassCard>
          <details class="cl-details">
            <summary class="cl-summary">
              <h2>Initial App Store Release</h2>
              <svg class="cl-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="cl-body">
              <div class="cl-group">
                <h3>Core Features</h3>
                <ul>
                  <li>Safe to Spend — a single daily number calculated from your remaining budget, upcoming bills, savings reserve, and days remaining.</li>
                  <li>Money Pools — track Cash, Debit, Credit, and Savings as distinct pools with individual balances.</li>
                  <li>Priority Categories — Critical, Important, Discretionary, and Buffer with 100+ SF Symbol icons.</li>
                  <li>Recurring Bills — due date tracking, payment status, and reminders up to 7 days in advance.</li>
                  <li>Savings Goals — visual progress rings with milestone celebrations at 25%, 50%, 75%, and 100%.</li>
                  <li>Budget Period management — archive, carryover, and period-end rollover.</li>
                </ul>
              </div>
              <div class="cl-group">
                <h3>Premium Features (at launch)</h3>
                <ul>
                  <li>Cloud Backup &amp; Restore — AES-256-GCM encrypted, up to 5 slots, instant restore.</li>
                  <li>Household Sharing — Admin, Member, and Viewer roles with 6-character invite codes.</li>
                  <li>Analytics &amp; Insights — month-over-month trends, spending predictions, subscription audit.</li>
                  <li>Calendar Sync — bill and subscription due dates in iOS Calendar.</li>
                  <li>Unlimited exports — CSV and PDF with full spending breakdowns.</li>
                </ul>
              </div>
            </div>
          </details>
        </GlassCard>
      </div>

    </div>
  </section>

  <CTASection
    heading="Always getting better."
    subheading="Feature requests are public and voteable. We build what you ask for."
    primaryLabel="Download BudgetBaby"
    primaryHref="https://apps.apple.com/app/id6756576123"
    secondaryLabel="Vote on features"
    secondaryHref="https://babyblocks.canny.io/feature-requests"
  />
</Layout>

<style>
  .changelog-hero {
    padding-top: calc(var(--space-20) + var(--space-8));
  }

  .changelog-hero-inner {
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .changelog-hero-inner h1 {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl));
    letter-spacing: -0.03em;
  }

  .changelog-hero-inner p {
    font-size: var(--text-lg);
    color: var(--text-secondary);
  }

  .changelog-body { padding-block: var(--space-4); }

  .cl-entry {
    margin-bottom: var(--space-6);
  }

  .cl-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .cl-version {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--accent-light);
    font-family: var(--font-mono);
  }

  .cl-date {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .cl-badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    padding: 2px var(--space-2);
    border-radius: var(--radius-full);
  }

  .cl-badge.new {
    background: rgba(52, 211, 153, 0.15);
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.25);
  }

  .cl-badge.launch {
    background: rgba(139, 92, 246, 0.15);
    color: var(--accent-light);
    border: 1px solid rgba(139, 92, 246, 0.25);
  }

  .cl-details { width: 100%; }

  .cl-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    cursor: pointer;
    list-style: none;
    transition: background 0.15s;
  }

  .cl-summary::-webkit-details-marker { display: none; }
  .cl-summary::marker { display: none; }
  .cl-summary:hover { background: var(--glass-bg-hover); border-radius: var(--radius-xl); }

  .cl-summary h2 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
  }

  .cl-chevron {
    flex-shrink: 0;
    color: var(--text-muted);
    transition: transform 0.2s ease;
  }

  details[open] .cl-chevron { transform: rotate(180deg); }

  .cl-body {
    padding: 0 var(--space-6) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .cl-group h3 {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-3);
  }

  .cl-group ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-4);
  }

  .cl-group li {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
</style>
