---
import Layout from '../../layouts/LayoutCore.astro';
import GlassCard from '../../components/GlassCard.astro';

const sections = [
  {
    id: 'getting-started',
    label: 'Getting Started',
    sub: [
      { id: 'onboarding',            label: 'First launch & onboarding' },
      { id: 'safe-to-spend',         label: 'Understanding Safe to Spend' },
      { id: 'logging-transactions',  label: 'Logging a transaction' },
      { id: 'budget-periods',        label: 'Budget periods' },
    ],
  },
  {
    id: 'accounts-sync',
    label: 'Accounts & Sync',
    sub: [
      { id: 'creating-account',   label: 'Creating an account' },
      { id: 'cloud-sync',         label: 'Cloud sync' },
      { id: 'household-sharing',  label: 'Household sharing' },
    ],
  },
  {
    id: 'subscriptions',
    label: 'Subscriptions & Billing',
    sub: [
      { id: 'free-vs-premium',       label: 'Free vs Premium' },
      { id: 'purchasing-premium',    label: 'Purchasing Premium' },
      { id: 'restoring-purchases',   label: 'Restoring purchases' },
      { id: 'cancelling',            label: 'Cancelling' },
    ],
  },
  {
    id: 'data-backups',
    label: 'Data & Backups',
    sub: [
      { id: 'local-data',      label: 'Where your data lives' },
      { id: 'cloud-backup',    label: 'Cloud backups' },
      { id: 'restore-backup',  label: 'Restoring from backup' },
      { id: 'export-data',     label: 'Exporting data' },
      { id: 'delete-data',     label: 'Deleting your data' },
    ],
  },
  {
    id: 'troubleshooting',
    label: 'Troubleshooting',
    sub: [
      { id: 'ts-before-support',  label: 'Before contacting support' },
      { id: 'ts-safe-to-spend',   label: 'Safe to Spend issues' },
      { id: 'ts-premium',         label: 'Premium not unlocking' },
      { id: 'ts-dates',           label: 'Transaction date issues' },
      { id: 'ts-backup',          label: 'Backup fails' },
      { id: 'ts-notifications',   label: 'Notifications' },
      { id: 'ts-crashes',         label: 'App crashes on launch' },
    ],
  },
];
---

<Layout
  title="BudgetBaby Documentation"
  description="Complete documentation for BudgetBaby: getting started, account setup, cloud sync, subscriptions, backups, and troubleshooting."
  canonical="/budgetbaby/documentation"
>
  <div class="docs-layout">
    <!-- Sidebar -->
    <aside class="docs-sidebar">
      <div class="sidebar-inner">
        <div class="sidebar-header">
          <a href="/budgetbaby" class="sidebar-back">← BudgetBaby</a>
          <h2 class="sidebar-title">Documentation</h2>
        </div>

        <nav class="sidebar-nav" aria-label="Documentation sections">
          <ul class="sidebar-list">
            {sections.map(s => (
              <li class="sidebar-item">
                <details class="sidebar-details" open>
                  <summary class="sidebar-summary" data-section={s.id}>
                    <span class="sidebar-section-label">{s.label}</span>
                    <svg class="sidebar-chevron" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                      <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </summary>
                  <ul class="sidebar-sub">
                    {s.sub.map(sub => (
                      <li>
                        <a
                          href={`#${sub.id}`}
                          class="sidebar-sub-link"
                          data-parent={s.id}
                        >{sub.label}</a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            ))}
          </ul>
        </nav>

        <div class="sidebar-support">
          <p>Can't find the answer?</p>
          <a href="/budgetbaby/support" class="btn btn-secondary" style="font-size: var(--text-xs); padding: var(--space-2) var(--space-3);">
            Contact Support
          </a>
        </div>
      </div>
    </aside>

    <!-- Content -->
    <main class="docs-content">
      <!-- Mobile section jump -->
      <div class="docs-mobile-jump">
        <label for="mobile-section-jump" class="docs-jump-label">Jump to section</label>
        <select id="mobile-section-jump" class="docs-jump-select">
          <option value="">Select a section...</option>
          {sections.map(s => (
            <>
              <option value={`#${s.id}`}>{s.label}</option>
              {s.sub.map(sub => (
                <option value={`#${sub.id}`}>&nbsp;&nbsp;{sub.label}</option>
              ))}
            </>
          ))}
        </select>
      </div>

      <div class="docs-header">
        <div class="label-chip">BudgetBaby</div>
        <h1>Documentation</h1>
        <p class="docs-intro">
          Everything you need to get the most out of BudgetBaby.
          Use the sidebar to jump to any section, or read top to bottom.
        </p>
      </div>

      <!-- Getting Started -->
      <section class="doc-section" id="getting-started">
        <h2>Getting Started</h2>

        <div class="doc-block">
          <h3 id="onboarding">First launch & onboarding</h3>
          <p>
            When you first open BudgetBaby, you'll go through an 8-step guided setup.
            It takes about 3 minutes and covers everything BudgetBaby needs to calculate your Safe to Spend number accurately.
          </p>
          <ol class="doc-list numbered">
            <li><strong>Welcome:</strong> Overview of the app and what to expect.</li>
            <li><strong>Pay Frequency:</strong> Choose weekly, bi-weekly, twice monthly, monthly, or custom. This sets your budget period length.</li>
            <li><strong>Income / Budget:</strong> Enter your take-home pay (after tax). This is your spending budget for the period.</li>
            <li><strong>Bucket Allocation:</strong> Split your budget into Needs, Wants, and Savings using percentage sliders. The default is 50/30/20.</li>
            <li><strong>Bucket Naming:</strong> Rename buckets if you prefer different labels (e.g., "Bills" instead of "Needs").</li>
            <li><strong>Priority Colors:</strong> Learn how Critical/Important/Discretionary/Buffer categories work.</li>
            <li><strong>Default Categories:</strong> Select the spending categories you want pre-loaded.</li>
            <li><strong>Review & Confirm:</strong> Review your setup and tap "Start budgeting."</li>
          </ol>
          <div class="doc-tip">
            <strong>Tip:</strong> You can change any of these settings later in Settings → Budget Setup.
            Your budget history is preserved when you edit settings.
          </div>
        </div>

        <div class="doc-block">
          <h3 id="safe-to-spend">Understanding Safe to Spend</h3>
          <p>
            Safe to Spend is the core number in BudgetBaby. It answers:
            <em>"How much can I spend right now without breaking my budget?"</em>
          </p>
          <p>The calculation is straightforward:</p>
          <div class="doc-formula glass">
            <code>Safe to Spend = (Remaining Budget − Upcoming Bills − Savings Reserve) ÷ Days Remaining</code>
          </div>
          <ul class="doc-list">
            <li><strong>Remaining Budget:</strong> Your total period budget minus everything already spent.</li>
            <li><strong>Upcoming Bills:</strong> Only unpaid Critical (red) bills due in the current period.</li>
            <li><strong>Savings Reserve:</strong> The savings portion of your budget allocation.</li>
            <li><strong>Days Remaining:</strong> Calendar days left in the period (minimum 1).</li>
          </ul>
          <p>The indicator color tells you your status at a glance:</p>
          <ul class="doc-list doc-status-list">
            <li><span class="status-dot green"></span><strong>Green:</strong> Healthy. Spend with confidence.</li>
            <li><span class="status-dot yellow"></span><strong>Yellow:</strong> Moderate. Be thoughtful.</li>
            <li><span class="status-dot orange"></span><strong>Orange:</strong> Limited. Avoid non-essentials.</li>
            <li><span class="status-dot red"></span><strong>Red:</strong> Critical or overspent. Pause discretionary spending.</li>
          </ul>
        </div>

        <div class="doc-block">
          <h3 id="logging-transactions">Logging a transaction</h3>
          <ol class="doc-list numbered">
            <li>Tap the <strong>+</strong> button on the Home screen (or in any transaction view).</li>
            <li>Enter the amount.</li>
            <li>Add a description (optional but recommended).</li>
            <li>Select a <strong>Category</strong> (this determines its priority colour and bucket).</li>
            <li>Choose the <strong>Payment Method</strong>: Cash, Debit, Credit, or Savings.</li>
            <li>Confirm the date (defaults to today).</li>
            <li>Tap <strong>Save</strong>.</li>
          </ol>
          <div class="doc-tip">
            <strong>Note on payment methods:</strong> Cash and Debit spending immediately reduces your pool balance.
            Credit spending counts toward your budget but doesn't reduce your Cash or Debit balance. It's deferred liability.
          </div>
        </div>

        <div class="doc-block">
          <h3 id="budget-periods">Budget periods</h3>
          <p>
            Your budget resets according to your pay frequency. At the end of a period, BudgetBaby archives it (read-only)
            and opens a new one.
          </p>
          <ul class="doc-list">
            <li><strong>Cash and Debit balances always carry forward.</strong> Your ending balance becomes the next period's starting balance.</li>
            <li><strong>Surplus budget</strong> (optional): If you have unspent budget, it rolls over and is displayed separately so you can see where it came from.</li>
            <li><strong>Bills</strong> are not rolled over. Each period generates its own bill occurrences.</li>
          </ul>
        </div>
      </section>

      <hr class="divider" />

      <!-- Accounts & Sync -->
      <section class="doc-section" id="accounts-sync">
        <h2>Accounts & Sync</h2>

        <div class="doc-block">
          <h3 id="creating-account">Creating an account</h3>
          <p>
            An account is not required to use BudgetBaby. All core features work without signing in.
            An account is needed for cloud sync, cloud backup, and household sharing.
          </p>
          <p>BudgetBaby supports three sign-in methods:</p>
          <ul class="doc-list">
            <li><strong>Sign in with Apple:</strong> Recommended. Apple handles authentication; we never see your email.</li>
            <li><strong>Sign in with Google:</strong> Requires a Google account.</li>
            <li><strong>Email and Password:</strong> Minimum 8 characters with uppercase, lowercase, and a number required.</li>
          </ul>
        </div>

        <div class="doc-block">
          <h3 id="cloud-sync">Cloud sync</h3>
          <p>
            Cloud sync keeps your data in sync across devices. It requires a signed-in account and an active internet connection.
          </p>
          <ul class="doc-list">
            <li>Sync is always opt-in. It is never enabled automatically.</li>
            <li>To enable: Settings → Account → Cloud Sync → Toggle on.</li>
            <li>Data is transmitted over TLS and stored encrypted at rest in Firebase Firestore.</li>
          </ul>
          <div class="doc-tip">
            <strong>Current status:</strong> Cloud sync is rolling out progressively. Cloud backup (available now for all signed-in users) is the recommended way to protect your data today.
          </div>
        </div>

        <div class="doc-block">
          <h3 id="household-sharing">Household sharing</h3>
          <p>
            Household sharing is a Premium feature that lets multiple people collaborate on a shared budget.
          </p>
          <ul class="doc-list">
            <li><strong>Create a household:</strong> Settings → Household → Create. Requires Premium.</li>
            <li><strong>Invite members:</strong> Generate a 6-character invite code. Valid for 48 hours.</li>
            <li><strong>Join a household:</strong> Settings → Household → Join with Code. Free users can join; they cannot create.</li>
            <li><strong>Roles:</strong> Admin (full control + invites), Member (contribute + view), Viewer (read-only).</li>
          </ul>
        </div>
      </section>

      <hr class="divider" />

      <!-- Subscriptions & Billing -->
      <section class="doc-section" id="subscriptions">
        <h2>Subscriptions & Billing</h2>

        <div class="doc-block">
          <h3 id="free-vs-premium">Free vs Premium</h3>
          <p>BudgetBaby is free to download and usable without a subscription. The free tier includes:</p>
          <ul class="doc-list">
            <li>Unlimited transactions and budget periods</li>
            <li>Safe to Spend calculation</li>
            <li>Money Pools (Cash, Debit, Credit, Savings)</li>
            <li>Priority categories with color coding</li>
            <li>Up to 3 savings goals</li>
            <li>Up to 5 recurring bills</li>
            <li>Up to 5 subscriptions</li>
            <li>Up to 3 important expenses</li>
            <li>1 cloud backup slot</li>
            <li>Basic spending insights</li>
          </ul>
          <p>Premium ($4.99/month or $39.99/year, saving 33%) unlocks:</p>
          <ul class="doc-list">
            <li>Unlimited savings goals, bills, subscriptions, and expenses</li>
            <li>Custom spending categories</li>
            <li>Advanced insights: trends, predictions, analytics</li>
            <li>iOS Calendar sync</li>
            <li>Household creation (up to 3 households)</li>
            <li>CSV and PDF data export</li>
            <li>Advanced reminders with custom schedules</li>
            <li>5 cloud backup slots</li>
            <li>Cloud sync (rolling out)</li>
          </ul>
        </div>

        <div class="doc-block">
          <h3 id="purchasing-premium">Purchasing Premium</h3>
          <ol class="doc-list numbered">
            <li>Open BudgetBaby and tap any locked Premium feature, or go to Settings → Premium.</li>
            <li>Review the monthly and annual options.</li>
            <li>Tap your preferred plan. Confirm with Face ID, Touch ID, or your Apple ID password.</li>
            <li>Premium activates immediately. No restart required.</li>
          </ol>
          <p>
            Subscriptions are managed through the App Store. BudgetBaby uses RevenueCat for subscription management.
            We never store your payment information.
          </p>
        </div>

        <div class="doc-block">
          <h3 id="restoring-purchases">Restoring purchases</h3>
          <p>
            If you reinstall BudgetBaby or sign in on a new device and Premium isn't showing:
          </p>
          <ol class="doc-list numbered">
            <li>Go to Settings → Premium.</li>
            <li>Tap <strong>"Restore Purchases."</strong></li>
            <li>Sign in with the Apple ID used to purchase Premium.</li>
            <li>Premium will be restored within a few seconds.</li>
          </ol>
          <p>
            If restore doesn't work, ensure you're signed in to the App Store with the correct Apple ID.
            Contact <a href="/budgetbaby/support">support</a> if the issue persists.
          </p>
        </div>

        <div class="doc-block">
          <h3 id="cancelling">Cancelling your subscription</h3>
          <p>
            BudgetBaby subscriptions are managed entirely by Apple. To cancel:
          </p>
          <ol class="doc-list numbered">
            <li>Open the Settings app on your iPhone.</li>
            <li>Tap your name → Subscriptions.</li>
            <li>Find BudgetBaby and tap it.</li>
            <li>Tap <strong>Cancel Subscription</strong>.</li>
          </ol>
          <p>
            Cancellation takes effect at the end of your current billing period. Your data is never deleted
            when you cancel. Only limits are re-applied.
          </p>
        </div>
      </section>

      <hr class="divider" />

      <!-- Data & Backups -->
      <section class="doc-section" id="data-backups">
        <h2>Data & Backups</h2>

        <div class="doc-block">
          <h3 id="local-data">Where your data lives</h3>
          <p>
            All your budget data is stored locally on your device using SwiftData. This means:
          </p>
          <ul class="doc-list">
            <li>Your data works without an internet connection.</li>
            <li>Uninstalling the app deletes your data. Create a backup before uninstalling.</li>
            <li>iCloud Drive does not automatically back up BudgetBaby data.</li>
          </ul>
        </div>

        <div class="doc-block">
          <h3 id="cloud-backup">Cloud backups</h3>
          <p>
            Cloud backup saves a full encrypted copy of your BudgetBaby data to the cloud.
            You can restore it on any device at any time.
          </p>
          <p><strong>To create a backup:</strong></p>
          <ol class="doc-list numbered">
            <li>Sign in to your BudgetBaby account (Settings → Account).</li>
            <li>Go to Settings → Backup & Restore.</li>
            <li>Tap <strong>Create Backup</strong>.</li>
          </ol>
          <p><strong>Backup includes:</strong> All budget periods, transactions, categories, accounts, recurring bills, subscriptions, savings goals, savings transactions, money transfers, and user settings.</p>
          <p><strong>Security:</strong> Backups are encrypted with AES-256-GCM before upload. The encryption key is stored in your iOS Keychain (synced via iCloud Keychain). We cannot read your backup data.</p>
          <p><strong>Quota:</strong> Free users get 1 backup slot. Premium users get 5 slots.</p>
        </div>

        <div class="doc-block">
          <h3 id="restore-backup">Restoring from backup</h3>
          <ol class="doc-list numbered">
            <li>Go to Settings → Backup & Restore.</li>
            <li>Select the backup you want to restore.</li>
            <li>Tap <strong>Restore</strong>. A safety backup of your current data is automatically created first.</li>
            <li>Confirm the restore. BudgetBaby restores your data in-memory. No app restart required.</li>
          </ol>
          <div class="doc-tip">
            <strong>Safety backups:</strong> Before any restore, BudgetBaby creates a local safety backup of your current data.
            If something goes wrong, you can restore from the safety backup.
          </div>
        </div>

        <div class="doc-block">
          <h3 id="export-data">Exporting your data (Premium)</h3>
          <p>Premium users can export their data in two formats:</p>
          <ul class="doc-list">
            <li>
              <strong>CSV:</strong> Includes transactions, categories, bills, subscriptions, savings goals, and budget periods.
              Dates are in ISO 8601 format (YYYY-MM-DD) for spreadsheet compatibility.
              Amounts are pure numbers (no currency symbol) with a separate currency column.
            </li>
            <li>
              <strong>PDF:</strong> A formatted financial summary report with spending breakdown by priority,
              monthly bills and subscriptions, and savings goals with progress bars.
            </li>
          </ul>
          <p>To export: Settings → Export Data → choose format → share via any iOS share sheet destination.</p>
        </div>

        <div class="doc-block">
          <h3 id="delete-data">Deleting your data</h3>
          <p>To completely reset BudgetBaby: Settings → About → Reset All Data.</p>
          <p>This action is permanent and cannot be undone. Create a backup first if you want to be able to restore.</p>
          <p>To delete your account and all cloud data: Settings → Account → Delete Account. This permanently deletes all cloud data including backups.</p>
        </div>
      </section>

      <hr class="divider" />

      <!-- Troubleshooting -->
      <section class="doc-section" id="troubleshooting">
        <h2>Troubleshooting</h2>

        <div class="doc-block">
          <h3 id="ts-before-support">Before you contact support</h3>
          <p>Most issues are resolved by one of the following:</p>
          <ul class="doc-list">
            <li><strong>Force-quit and reopen the app.</strong> Swipe up from the Home bar to quit, then reopen.</li>
            <li><strong>Check your iOS version.</strong> BudgetBaby requires iOS 17.0 or later. Go to Settings → General → About to check.</li>
            <li><strong>Ensure the app is up to date.</strong> Open the App Store → your profile → check for updates.</li>
            <li><strong>Check your internet connection</strong> if cloud features aren't working.</li>
          </ul>
        </div>

        <div class="doc-block">
          <h3 id="ts-safe-to-spend">Safe to Spend shows an unexpected number</h3>
          <ul class="doc-list">
            <li>Make sure your active budget period dates are correct (Settings → Budget Setup).</li>
            <li>Check that your upcoming bills are assigned to the correct period and are marked as unpaid.</li>
            <li>Verify your savings target (the allocation percentage in Budget Setup) is what you intend.</li>
            <li>Tap the info button next to Safe to Spend to see the full breakdown.</li>
          </ul>
        </div>

        <div class="doc-block">
          <h3 id="ts-premium">Premium features not unlocking after purchase</h3>
          <ol class="doc-list numbered">
            <li>Go to Settings → Premium → Restore Purchases.</li>
            <li>Wait 30 seconds and check again.</li>
            <li>Force-quit and reopen the app.</li>
            <li>Ensure you're signed in to the App Store with the purchasing Apple ID.</li>
            <li>Contact <a href="/budgetbaby/support">support</a> with your order number if the issue persists.</li>
          </ol>
        </div>

        <div class="doc-block">
          <h3 id="ts-dates">Transactions appearing on the wrong day</h3>
          <p>
            BudgetBaby normalises all transaction dates to noon UTC to prevent timezone-related date shifts.
            If you're seeing dates that are off by one day:
          </p>
          <ul class="doc-list">
            <li>Update BudgetBaby to the latest version (v2.0.5 and later include this fix).</li>
            <li>Re-save the affected transactions to apply the timezone fix to existing records.</li>
          </ul>
        </div>

        <div class="doc-block">
          <h3 id="ts-backup">Cloud backup fails</h3>
          <ul class="doc-list">
            <li>Verify you're signed in to your account (Settings → Account).</li>
            <li>Check your internet connection.</li>
            <li>Free users have 1 backup slot. If it's occupied, delete the existing backup first.</li>
            <li>If errors persist, contact <a href="/budgetbaby/support">support</a> with your account email.</li>
          </ul>
        </div>

        <div class="doc-block">
          <h3 id="ts-notifications">Notifications aren't arriving</h3>
          <ul class="doc-list">
            <li>Check that notifications are enabled: iOS Settings → BudgetBaby → Notifications → Allow Notifications.</li>
            <li>In BudgetBaby: Settings → Notifications, and verify your alert preferences.</li>
            <li>Note: Bill due-day alerts (free) always work. 3-day and 7-day reminders require Premium.</li>
          </ul>
        </div>

        <div class="doc-block">
          <h3 id="ts-crashes">App crashes on launch</h3>
          <p>This is rare and usually caused by a corrupted data store. Steps to resolve:</p>
          <ol class="doc-list numbered">
            <li>Update the app to the latest version.</li>
            <li>If you have a cloud backup, uninstall and reinstall the app, then restore your backup.</li>
            <li>If no backup is available, uninstall and reinstall to start fresh.</li>
            <li>Contact <a href="/budgetbaby/support">support</a> with your iOS version and app version before uninstalling. We may be able to help recover data.</li>
          </ol>
        </div>

        <div class="doc-contact">
          <GlassCard>
            <div class="doc-contact-inner">
              <h3>Still stuck?</h3>
              <p>
                Email our support team at <a href="mailto:support@babyblocks.io">support@babyblocks.io</a>.
                Include your iOS version, app version (Settings → About), and a description of the issue.
              </p>
              <a href="/budgetbaby/support" class="btn btn-secondary">
                Visit Support →
              </a>
            </div>
          </GlassCard>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  .docs-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: calc(100dvh - var(--nav-height));
    max-width: var(--max-w-xl);
    margin-inline: auto;
    padding-inline: var(--space-5);
    gap: var(--space-12);
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    align-items: start;
  }

  /* ── Sidebar ── */
  .docs-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-6));
    max-height: calc(100dvh - var(--nav-height) - var(--space-12));
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--glass-border) transparent;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .sidebar-back {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
    display: block;
    margin-bottom: var(--space-1);
  }
  .sidebar-back:hover { color: var(--text-secondary); }

  .sidebar-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
  }

  .sidebar-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .sidebar-item { list-style: none; }

  /* Details/summary reset */
  .sidebar-details { list-style: none; }
  .sidebar-details > summary { list-style: none; }
  .sidebar-details > summary::-webkit-details-marker { display: none; }

  .sidebar-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-secondary);
    border-radius: var(--radius-md);
    cursor: pointer;
    user-select: none;
    transition: all 0.15s ease;
  }

  .sidebar-summary:hover {
    color: var(--text-primary);
    background: var(--glass-bg);
  }

  .sidebar-summary.active-section {
    color: var(--accent-light);
  }

  .sidebar-section-label { flex: 1; }

  .sidebar-chevron {
    color: var(--text-faint);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .sidebar-details[open] .sidebar-chevron {
    transform: rotate(180deg);
  }

  /* Sub-items */
  .sidebar-sub {
    list-style: none;
    padding-left: var(--space-3);
    padding-bottom: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 1px solid var(--glass-border);
    margin-left: var(--space-3);
    margin-top: var(--space-1);
  }

  .sidebar-sub-link {
    display: block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    color: var(--text-muted);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all 0.12s ease;
    line-height: var(--leading-snug);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sidebar-sub-link:hover {
    color: var(--text-secondary);
    background: var(--glass-bg);
  }

  .sidebar-sub-link.active {
    color: var(--accent-light);
    background: var(--accent-dim);
    font-weight: var(--weight-medium);
  }

  .sidebar-support {
    padding-top: var(--space-4);
    border-top: 1px solid var(--glass-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .sidebar-support p {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  /* ── Content ── */
  .docs-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--glass-border);
  }

  .docs-header h1 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    margin-top: var(--space-4);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .docs-intro {
    font-size: var(--text-base);
    color: var(--text-secondary);
    max-width: 52ch;
  }

  .doc-section {
    margin-bottom: var(--space-8);
  }

  .doc-section h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--glass-border);
  }

  .doc-block {
    margin-bottom: var(--space-10);
  }

  .doc-block h3 {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    scroll-margin-top: calc(var(--nav-height) + var(--space-8));
  }

  .doc-block p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
  }

  .doc-block p:last-child { margin-bottom: 0; }

  .doc-list {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    padding-left: var(--space-6);
    margin-block: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .doc-list.numbered { list-style: decimal; }
  .doc-list:not(.numbered) { list-style: disc; }

  .doc-status-list { list-style: none; padding-left: 0; }

  .doc-status-list li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-dot.green  { background: var(--green); }
  .status-dot.yellow { background: var(--yellow); }
  .status-dot.orange { background: #F97316; }
  .status-dot.red    { background: var(--red); }

  .doc-formula {
    padding: var(--space-4) var(--space-5);
    margin-block: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--purple-300);
    border-radius: var(--radius-lg);
    border-color: var(--accent-border);
    background: var(--accent-dim);
    overflow-x: auto;
  }

  .doc-tip {
    margin-top: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: rgba(251, 191, 36, 0.06);
    border: 1px solid rgba(251, 191, 36, 0.2);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .doc-contact { margin-top: var(--space-8); }

  .doc-contact-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .doc-contact-inner h3 { font-size: var(--text-xl); }
  .doc-contact-inner p  { font-size: var(--text-sm); }

  .divider {
    border: none;
    border-top: 1px solid var(--glass-border);
    margin-block: var(--space-12);
  }

  /* Mobile jump-to dropdown */
  .docs-mobile-jump {
    display: none;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    padding: var(--space-4);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
  }

  .docs-jump-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .docs-jump-select {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    color: var(--text-primary);
    background: var(--bg-surface);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    appearance: auto;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .docs-layout {
      grid-template-columns: 1fr;
      padding-top: var(--space-6);
    }
    .docs-sidebar {
      position: static;
      max-height: none;
      overflow-y: visible;
    }
    .sidebar-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2);
    }
    .sidebar-details[open] .sidebar-sub {
      display: flex;
    }
    .docs-mobile-jump { display: flex; }
  }

  @media (max-width: 560px) {
    .sidebar-list { grid-template-columns: 1fr; }
  }
</style>

<script>
  const docHeadings = document.querySelectorAll<HTMLElement>('.doc-block h3[id]');
  const sidebarSummaries = document.querySelectorAll<HTMLElement>('.sidebar-summary');
  const sidebarSubLinks = document.querySelectorAll<HTMLAnchorElement>('.sidebar-sub-link');

  function clearActive() {
    sidebarSummaries.forEach(s => s.classList.remove('active-section'));
    sidebarSubLinks.forEach(l => l.classList.remove('active'));
  }

  function activateHeading(id: string) {
    clearActive();
    const activeLink = document.querySelector<HTMLAnchorElement>(`.sidebar-sub-link[href="#${id}"]`);
    if (!activeLink) return;

    activeLink.classList.add('active');

    const parentId = activeLink.getAttribute('data-parent');
    if (parentId) {
      const parentSummary = document.querySelector<HTMLElement>(`.sidebar-summary[data-section="${parentId}"]`);
      parentSummary?.classList.add('active-section');

      const parentDetails = parentSummary?.closest<HTMLDetailsElement>('.sidebar-details');
      if (parentDetails) parentDetails.open = true;
    }
  }

  if (docHeadings.length && sidebarSubLinks.length) {
    // Set initial active state to first sub-link
    const firstLink = sidebarSubLinks[0];
    if (firstLink) {
      firstLink.classList.add('active');
      const firstParentId = firstLink.getAttribute('data-parent');
      const firstSummary = document.querySelector<HTMLElement>(`.sidebar-summary[data-section="${firstParentId}"]`);
      firstSummary?.classList.add('active-section');
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            activateHeading(entry.target.id);
          }
        });
      },
      { rootMargin: '-10% 0px -78% 0px', threshold: 0 }
    );

    docHeadings.forEach(h => observer.observe(h));
  }

  // Mobile jump-to-section dropdown
  const jumpSelect = document.getElementById('mobile-section-jump') as HTMLSelectElement | null;
  if (jumpSelect) {
    jumpSelect.addEventListener('change', () => {
      const val = jumpSelect.value;
      if (val) {
        window.location.hash = val;
        jumpSelect.value = '';
      }
    });
  }
</script>
