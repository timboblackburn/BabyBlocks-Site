---
import Layout from '../../layouts/Layout.astro';
import GlassCard from '../../components/GlassCard.astro';
import Icon from '../../components/Icon.astro';

const commonIssues = [
  {
    title: 'Safe to Spend seems wrong',
    steps: [
      'Tap the info icon next to Safe to Spend to see the full calculation breakdown.',
      'Check your budget period dates (Settings → Budget Setup).',
      'Verify your recurring bills are marked correctly (paid vs unpaid).',
      'Confirm your savings allocation percentage reflects your intent.',
    ],
  },
  {
    title: 'Premium didn\'t unlock after purchase',
    steps: [
      'Go to Settings → Premium → Restore Purchases.',
      'Wait 30 seconds, then force-quit and reopen the app.',
      'Verify you\'re signed in to the App Store with the correct Apple ID.',
      'If still not resolved, contact us with your App Store order number.',
    ],
  },
  {
    title: 'Cloud backup failed',
    steps: [
      'Confirm you\'re signed in to your account (Settings → Account).',
      'Check your internet connection.',
      'Free users have 1 backup slot. Delete the existing one to create a new backup.',
      'If the error persists, contact us with your account email.',
    ],
  },
  {
    title: 'App is slow or crashing',
    steps: [
      'Update BudgetBaby to the latest version via the App Store.',
      'Force-quit the app (swipe up from Home bar) and reopen.',
      'Restart your iPhone.',
      'If crashes continue, contact us with your iOS version and app version.',
    ],
  },
  {
    title: 'Notifications aren\'t arriving',
    steps: [
      'Check iOS Settings → BudgetBaby → Notifications → Allow Notifications.',
      'In BudgetBaby, go to Settings → Notifications and verify your preferences.',
      'Note: Reminders 3 days and 7 days in advance require Premium.',
    ],
  },
];
---

<Layout
  title="BudgetBaby Support"
  description="Get help with BudgetBaby. Before you email us, check the common issues list. Our support email is support@babyblocks.io."
  canonical="/budgetbaby/support"
>
  <section class="support-hero section">
    <div class="container">
      <div class="label-chip">BudgetBaby</div>
      <h1>Support</h1>
      <p class="support-intro">
        We take support seriously. Before emailing us, please check the steps below.
        Most issues are resolved without needing to wait for a reply.
      </p>
    </div>
  </section>

  <!-- Before you email us -->
  <section class="checklist-section section-sm">
    <div class="container-sm">
      <h2 class="section-h2">Before you email us</h2>
      <GlassCard>
        <ul class="preflight-list">
          <li>
            <span class="preflight-check"><Icon name="check" size={12} /></span>
            <div>
              <strong>Check your iOS version.</strong>
              BudgetBaby requires iOS 17.0 or later.
              Go to iOS Settings → General → About.
            </div>
          </li>
          <li>
            <span class="preflight-check"><Icon name="check" size={12} /></span>
            <div>
              <strong>Update the app.</strong>
              Open the App Store, tap your profile icon, and look for BudgetBaby under available updates.
            </div>
          </li>
          <li>
            <span class="preflight-check"><Icon name="check" size={12} /></span>
            <div>
              <strong>Force-quit and reopen.</strong>
              Swipe up from the Home bar, find BudgetBaby, and swipe it away. Then reopen.
            </div>
          </li>
          <li>
            <span class="preflight-check"><Icon name="check" size={12} /></span>
            <div>
              <strong>Read the documentation.</strong>
              Most "why does this work this way?" questions are answered in the <a href="/budgetbaby/documentation">docs</a>.
            </div>
          </li>
          <li>
            <span class="preflight-check"><Icon name="check" size={12} /></span>
            <div>
              <strong>Restart your iPhone.</strong>
              A full restart resolves a surprising number of transient issues.
            </div>
          </li>
        </ul>
      </GlassCard>
    </div>
  </section>

  <!-- Common Issues -->
  <section class="common-section section-sm">
    <div class="container-sm">
      <h2 class="section-h2">Common issues</h2>

      <div class="issues-list">
        {commonIssues.map((issue) => (
          <details class="issue-item glass" name="issue">
            <summary class="issue-summary">
              <span>{issue.title}</span>
              <svg class="faq-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="issue-body">
              <ol class="issue-steps">
                {issue.steps.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact-section section-sm">
    <div class="container-sm">
      <h2 class="section-h2">Contact support</h2>

      <GlassCard accent padding="lg">
        <div class="contact-inner">
          <div class="contact-text">
            <h3>We're here to help.</h3>
            <p>
              If the steps above didn't resolve your issue, email us directly:
            </p>
            <a href="mailto:support@babyblocks.io" class="contact-email">
              support@babyblocks.io
            </a>

            <p class="contact-note">What to include in your report:</p>
            <div class="report-template">
              <pre>Subject: [Issue] — BudgetBaby vX.X
App version:  Settings → About
iOS version:  Settings → General → About
Steps to reproduce:
  1.
  2.
  3.
Screenshots attached: yes / no</pre>
            </div>
          </div>

          <div class="response-box">
            <h4>Response promise</h4>
            <div class="response-row">
              <span>All issues</span>
              <span class="response-val">1–2 business days</span>
            </div>
            <div class="response-row">
              <span>Data loss reports</span>
              <span class="response-val green-val">Flagged same day</span>
            </div>
            <div class="response-row">
              <span>Feature requests</span>
              <span class="response-val">Tracked separately</span>
            </div>
            <p class="response-note">
              Every email is read personally. We reply — no ticket systems, no bots.
            </p>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- Feature requests -->
  <section class="feature-request-section section-sm">
    <div class="container-sm">
      <GlassCard>
        <div class="feature-request-inner">
          <div class="fr-icon"><Icon name="zap" size={28} /></div>
          <div>
            <h3>Have a feature idea?</h3>
            <p>
              Feature requests are tracked separately from support issues.
              You can submit and vote on ideas at our public feature board.
            </p>
            <a href="https://babyblocks.canny.io/feature-requests" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
              Submit a feature request →
            </a>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>
</Layout>

<style>
  .support-hero {
    padding-top: calc(var(--space-20) + var(--space-8));
    padding-bottom: var(--space-8);
  }

  .support-hero h1 {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
    letter-spacing: -0.03em;
    margin-top: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .support-intro {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 52ch;
  }

  .section-h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
  }

  .preflight-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .preflight-list li {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .preflight-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(52, 211, 153, 0.15);
    color: var(--green);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .preflight-list strong {
    display: block;
    margin-bottom: var(--space-1);
    font-size: var(--text-sm);
  }

  .preflight-list div {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .issues-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .issue-item {
    border-radius: var(--radius-lg) !important;
    overflow: hidden;
  }

  .issue-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    transition: background 0.15s;
  }

  .issue-summary::-webkit-details-marker { display: none; }
  .issue-summary::marker { display: none; }
  .issue-summary:hover { background: var(--glass-bg-hover); }

  .faq-chevron { transition: transform 0.2s ease; flex-shrink: 0; color: var(--text-muted); }
  details[open] .faq-chevron { transform: rotate(180deg); }

  .issue-body {
    padding: 0 var(--space-6) var(--space-5);
  }

  .issue-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    padding-left: var(--space-5);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-10);
    align-items: start;
  }

  .contact-text h3 { font-size: var(--text-xl); margin-bottom: var(--space-3); }

  .contact-text p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
  }

  .contact-email {
    display: inline-block;
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--accent-light);
    text-decoration: none;
    margin-bottom: var(--space-5);
    transition: color 0.15s;
  }
  .contact-email:hover { color: var(--purple-300); }

  .contact-note {
    font-size: var(--text-sm);
    color: var(--text-muted) !important;
    margin-bottom: var(--space-2) !important;
  }

  .contact-list {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .response-box {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .response-box h4 {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-1);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: var(--text-xs);
  }

  .response-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .response-val {
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
    text-align: right;
    flex-shrink: 0;
  }

  .response-note {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--space-2);
    line-height: var(--leading-relaxed);
    border-top: 1px solid var(--glass-border);
    padding-top: var(--space-3);
  }

  .feature-request-inner {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
  }

  .fr-icon {
    color: var(--accent-light);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .report-template {
    background: var(--bg-surface, rgba(0,0,0,0.2));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
    overflow-x: auto;
  }

  .report-template pre {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0;
    white-space: pre;
  }

  .green-val { color: var(--green) !important; }

  .feature-request-inner h3 { font-size: var(--text-xl); margin-bottom: var(--space-2); }

  .feature-request-inner p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-4);
  }

  @media (max-width: 768px) {
    .contact-inner { grid-template-columns: 1fr; }
    .feature-request-inner { flex-direction: column; }
  }
</style>
