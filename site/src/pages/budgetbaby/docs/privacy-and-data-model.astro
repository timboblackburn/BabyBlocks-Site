const headings = [
  { id: 'on-device',          text: 'On-device data' },
  { id: 'cloud-data',         text: 'Cloud data (opt-in)' },
  { id: 'what-we-never-do',  text: 'What we never do' },
  { id: 'third-party',        text: 'Third-party services' },
