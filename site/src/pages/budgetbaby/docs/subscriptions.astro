---
import DocsLayout from '../../../layouts/DocsLayout.astro';

const headings = [
  { id: 'free-vs-premium',     text: 'Free vs Premium' },
  { id: 'feature-comparison',  text: 'Full feature comparison' },
  { id: 'purchasing',          text: 'Purchasing Premium' },
  { id: 'restoring-purchases', text: 'Restoring purchases' },
  { id: 'cancelling',          text: 'Cancelling' },
  { id: 'refunds',             text: 'Refunds' },
];
---

<DocsLayout
  title="Plans and Purchases"
  description="BudgetBaby free and Premium plan comparison, full feature matrix, how to purchase, restore, cancel, and request refunds."
  canonical="/budgetbaby/docs/subscriptions"
  headings={headings}
>
  <div class="docs-content">
    <h1>Plans and Purchases</h1>
    <p class="docs-summary">
      BudgetBaby is free to download and fully usable without a subscription. Premium removes every
      limit and unlocks advanced features. All billing goes through Apple. We never touch your payment details.
    </p>

    <h2 id="free-vs-premium">Free vs Premium</h2>

    <div class="plan-grid">
      <!-- Free -->
      <div class="plan-card">
        <div class="plan-header">
          <div class="plan-name">Free</div>
          <div class="plan-pricing">
            <span class="plan-price">$0</span>
            <span class="plan-period">always</span>
          </div>
          <p class="plan-tagline">Everything you need to start budgeting today. No credit card, no trial.</p>
        </div>

        <ul class="plan-features">
          <li class="pf-check">Unlimited transactions and budget periods</li>
          <li class="pf-check">Safe to Spend calculation</li>
          <li class="pf-check">All four Money Pools</li>
          <li class="pf-check">Priority categories with color coding</li>
          <li class="pf-check">Basic spending breakdown</li>
          <li class="pf-check">Same-day bill reminders</li>
          <li class="pf-check">1 cloud backup slot</li>
          <li class="pf-limit">Up to 3 bills, 3 subscriptions, 3 goals</li>
          <li class="pf-limit">Up to 5 custom categories</li>
          <li class="pf-limit">1 CSV export per month</li>
          <li class="pf-off">Advanced insights and analytics</li>
          <li class="pf-off">PDF export</li>
          <li class="pf-off">Multi-day and subscription reminders</li>
        </ul>

        <a
          href="https://apps.apple.com/app/id6756576123"
          class="plan-action plan-action-free"
          target="_blank"
          rel="noopener noreferrer"
        >
          Download Free
        </a>
      </div>

      <!-- Premium -->
      <div class="plan-card plan-premium">
        <div class="plan-recommended">Best Value</div>

        <div class="plan-header">
          <div class="plan-name">Premium</div>
          <div class="plan-pricing">
            <span class="plan-price">$7.99</span>
            <span class="plan-period">/month</span>
          </div>
          <div class="plan-alt-price">or $69.99/year &mdash; save 27%</div>
          <p class="plan-tagline">Everything in Free, unlimited. Plus every advanced feature we build.</p>
        </div>

        <ul class="plan-features">
          <li class="pf-check pf-star">Everything in Free</li>
          <li class="pf-check">Unlimited bills, subscriptions, goals</li>
          <li class="pf-check">Unlimited custom categories and expenses</li>
          <li class="pf-check">Advanced insights, trends, and analytics</li>
          <li class="pf-check">Unlimited CSV and PDF exports</li>
          <li class="pf-check">iOS Calendar sync</li>
          <li class="pf-check">5 cloud backup slots</li>
          <li class="pf-check">Multi-day bill reminders (3 days, 1 week)</li>
          <li class="pf-check">Per-subscription reminders</li>
          <li class="pf-check">Custom reminder messages</li>
          <li class="pf-check">Quiet hours for notifications</li>
          <li class="pf-check">Monthly savings nudge</li>
          <li class="pf-check">Cloud sync (rolling out)</li>
          <li class="pf-soon">Household sharing</li>
        </ul>

        <div class="plan-upgrade-note">
          Upgrade inside the app: Settings → Premium
        </div>
      </div>
    </div>

    <div class="plan-note">
      <strong>Your data is never deleted when you cancel or hit free tier limits.</strong>
      If you downgrade from Premium, your existing data stays intact. You simply cannot add new
      items beyond the free limit until you resubscribe or remove old ones.
    </div>

