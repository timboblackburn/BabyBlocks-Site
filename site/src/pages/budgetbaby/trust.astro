---
import Layout from '../../layouts/Layout.astro';
import GlassCard from '../../components/GlassCard.astro';
import CTASection from '../../components/CTASection.astro';
import Icon from '../../components/Icon.astro';

const lastUpdated = 'March 1, 2026';
---

<Layout
  title="Trust & Privacy — BudgetBaby"
  description="How BudgetBaby handles your data. On-device storage, encrypted cloud backups, no bank connections, and no data selling. Full transparency."
  canonical="/budgetbaby/trust"
>
  <!-- Hero -->
  <section class="trust-hero section">
    <div class="container">
      <div class="trust-hero-inner">
        <div class="label-chip">BudgetBaby</div>
        <h1>Your data is yours.<br /><span class="text-gradient">Here's exactly what that means.</span></h1>
        <p>
          You deserve a clear, honest explanation of what happens to your financial data —
          not buried in a privacy policy, but front and center. This page is that explanation.
        </p>
        <p class="trust-updated">Last updated: {lastUpdated}</p>
      </div>
    </div>
  </section>

  <!-- On-device data -->
  <section class="trust-section section-sm">
    <div class="container-sm">
      <GlassCard accent padding="lg">
        <div class="trust-block">
          <div class="trust-block-icon"><Icon name="server" size={28} /></div>
          <div>
            <h2>Your budget lives on your device.</h2>
            <p>
              BudgetBaby stores all your data locally using SwiftData, Apple's native persistence framework.
              Your transactions, budgets, categories, bills, and goals are written to your device's local storage —
              not to our servers.
            </p>
            <ul class="trust-list">
              <li><Icon name="check" size={14} /> Stored using SwiftData on your iPhone</li>
              <li><Icon name="check" size={14} /> Protected by iOS encryption at rest (your device passcode/Face ID)</li>
              <li><Icon name="check" size={14} /> Never sent anywhere without your explicit action</li>
              <li><Icon name="check" size={14} /> Deleted permanently when you use "Reset All Data" in Settings → About</li>
            </ul>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- Cloud data -->
  <section class="trust-section section-sm">
    <div class="container-sm">
      <GlassCard padding="lg">
        <div class="trust-block">
          <div class="trust-block-icon"><Icon name="cloud-upload" size={28} /></div>
          <div>
            <h2>Cloud backup is opt-in and encrypted.</h2>
            <p>
              If you choose to enable cloud backup, your data is encrypted on your device before it ever leaves.
              We use AES-256-GCM encryption. The encryption key lives in your iCloud Keychain — not on our servers.
            </p>
            <ul class="trust-list">
              <li><Icon name="check" size={14} /> Encrypted with AES-256-GCM before leaving your device</li>
              <li><Icon name="check" size={14} /> Encryption key stored in your iCloud Keychain — we cannot access it</li>
              <li><Icon name="check" size={14} /> We cannot read the contents of your backup</li>
              <li><Icon name="check" size={14} /> Requires explicit sign-in. Off by default.</li>
              <li><Icon name="check" size={14} /> Free: 1 backup slot. Premium: 5 slots.</li>
            </ul>
            <p class="trust-note">
              A safety backup is automatically created before any restore operation.
              You can roll back if anything goes wrong.
            </p>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- What we never do -->
  <section class="trust-section section-sm">
    <div class="container-sm">
      <GlassCard glow padding="lg">
        <div class="trust-block">
          <div class="trust-block-icon never"><Icon name="shield" size={28} /></div>
          <div>
            <h2>What we never do.</h2>
            <p>Some things should not need a policy to explain. We are stating them plainly anyway.</p>
            <ul class="trust-list never-list">
              <li><Icon name="x-circle" size={14} /> Connect to your bank or financial institution</li>
              <li><Icon name="x-circle" size={14} /> Sell your data to third parties</li>
              <li><Icon name="x-circle" size={14} /> Use your financial data for advertising</li>
              <li><Icon name="x-circle" size={14} /> Read the contents of your budget or transactions</li>
              <li><Icon name="x-circle" size={14} /> Share data with advertisers or data brokers</li>
              <li><Icon name="x-circle" size={14} /> Require an account to use the core app</li>
            </ul>
            <p class="trust-note">
              We make money from subscriptions. That's it. Your data is not the product.
            </p>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- Third-party services -->
  <section class="trust-section section-sm">
    <div class="container-sm">
      <GlassCard padding="lg">
        <div class="trust-block">
          <div class="trust-block-icon"><Icon name="globe" size={28} /></div>
          <div>
            <h2>Third-party services we use.</h2>
            <p>We use a small number of third-party services. Here is what each does and what data it receives.</p>

            <div class="services-table-wrap">
              <table class="services-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Purpose</th>
                    <th>Data received</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Firebase Auth</td>
                    <td>Account authentication for cloud features</td>
                    <td>Email address, anonymized device ID</td>
                  </tr>
                  <tr>
                    <td>Firebase Crashlytics</td>
                    <td>Crash reporting</td>
                    <td>Stack traces, device model, iOS version. No financial data.</td>
                  </tr>
                  <tr>
                    <td>Firebase Analytics</td>
                    <td>Anonymous usage analytics</td>
                    <td>Anonymized feature usage events. No personal or financial data.</td>
                  </tr>
                  <tr>
                    <td>RevenueCat</td>
                    <td>Subscription management</td>
                    <td>App Store receipt data, subscription status. No financial data.</td>
                  </tr>
                  <tr>
                    <td>Apple StoreKit</td>
                    <td>In-app purchases</td>
                    <td>Handled entirely by Apple. We receive only subscription status.</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <p class="trust-note">
              You can opt out of Firebase Analytics via iOS App Tracking Transparency. Crash reporting helps us fix bugs — it contains no financial data.
            </p>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- Backup model -->
  <section class="trust-section section-sm">
    <div class="container-sm">
      <GlassCard padding="lg">
        <div class="trust-block">
          <div class="trust-block-icon"><Icon name="refresh-cw" size={28} /></div>
          <div>
            <h2>How backup and restore works.</h2>
            <p>
              Cloud backup uploads an encrypted snapshot of your entire dataset.
              Restore is an atomic operation: we load the backup into a staging context,
              create a safety snapshot of your current data, then commit the restore.
              If anything fails, you can roll back to the safety snapshot.
            </p>
            <ul class="trust-list">
              <li><Icon name="check" size={14} /> Safety backup auto-created before every restore</li>
              <li><Icon name="check" size={14} /> Atomic commit — either all data restores or none of it</li>
              <li><Icon name="check" size={14} /> Rollback available if restore fails</li>
              <li><Icon name="check" size={14} /> No app restart required after restore</li>
            </ul>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- What could change -->
  <section class="trust-section section-sm">
    <div class="container-sm">
      <GlassCard padding="lg">
        <div class="trust-block">
          <div class="trust-block-icon"><Icon name="alert-circle" size={28} /></div>
          <div>
            <h2>What could change.</h2>
            <p>
              We are committed to the principles above. But BudgetBaby will grow, and we want to be honest
              about what might evolve — so you are never surprised.
            </p>
            <ul class="trust-list change-list">
              <li><Icon name="info" size={14} /> New features may store additional data types on-device (for example, receipt photos or household member activity). The same on-device-first principle applies.</li>
              <li><Icon name="info" size={14} /> If we add a new third-party service, this page will be updated before it goes live in the app.</li>
              <li><Icon name="info" size={14} /> Cloud backup will always be opt-in. We will not change this without giving you advance notice and a clear way to opt out.</li>
              <li><Icon name="info" size={14} /> Analytics will remain anonymous. We will not add behavioral targeting or ad-network integration.</li>
              <li><Icon name="info" size={14} /> If we are ever acquired or materially change our business model, we will publish a clear notice and give users time to export or delete their data.</li>
            </ul>
            <p class="trust-note">
              This is not a legal contract. It is a written commitment. We take it seriously.
            </p>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- Support -->
  <section class="trust-section section-sm">
    <div class="container-sm">
      <GlassCard padding="lg">
        <div class="trust-block">
          <div class="trust-block-icon"><Icon name="mail" size={28} /></div>
          <div>
            <h2>Questions? Real humans read every email.</h2>
            <p>
              If you have questions about how your data is handled, email us at
              <a href="mailto:support@babyblocks.io">support@babyblocks.io</a>.
              We respond within 1–2 business days. Data-related issues are flagged same day.
            </p>
            <p>
              You can also read the full <a href="/budgetbaby/privacy">Privacy Policy</a> and
              <a href="/budgetbaby/terms">Terms of Use</a> for the complete legal text.
            </p>
          </div>
        </div>
      </GlassCard>
    </div>
  </section>

  <CTASection
    heading="Start with BudgetBaby."
    subheading="Local-first, privacy-respecting, and free to download."
    primaryLabel="Download on the App Store"
    primaryHref="https://apps.apple.com/app/id6756576123"
    secondaryLabel="Read the Privacy Policy"
    secondaryHref="/budgetbaby/privacy"
  />
</Layout>

<style>
  .trust-hero {
    padding-top: calc(var(--space-20) + var(--space-8));
  }

  .trust-hero-inner {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .trust-hero-inner h1 {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
    letter-spacing: -0.03em;
  }

  .trust-hero-inner p {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 56ch;
  }

  .trust-updated {
    font-size: var(--text-xs) !important;
    color: var(--text-muted) !important;
    max-width: none !important;
  }

  .trust-section { padding-block: var(--space-4); }

  .trust-block {
    display: flex;
    gap: var(--space-6);
  }

  .trust-block-icon {
    color: var(--accent-light);
    flex-shrink: 0;
    padding-top: var(--space-1);
  }

  .trust-block-icon.never { color: var(--green); }

  .trust-block h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-4);
  }

  .trust-block p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .trust-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .trust-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .trust-list li svg { color: var(--green); flex-shrink: 0; margin-top: 2px; }

  .never-list li svg { color: var(--red, #f87171); }

  .change-list li svg { color: var(--accent-light); }

  .trust-note {
    font-size: var(--text-xs) !important;
    color: var(--text-muted) !important;
    margin-bottom: 0 !important;
    padding-top: var(--space-3);
    border-top: 1px solid var(--glass-border);
  }

  /* Services table */
  .services-table-wrap {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-border);
    margin: var(--space-5) 0;
  }

  .services-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .services-table th {
    padding: var(--space-3) var(--space-4);
    text-align: left;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--glass-border);
    background: var(--glass-bg);
  }

  .services-table td {
    padding: var(--space-3) var(--space-4);
    color: var(--text-secondary);
    border-bottom: 1px solid var(--glass-border);
    line-height: var(--leading-relaxed);
  }

  .services-table tr:last-child td { border-bottom: none; }
  .services-table td:first-child {
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
    white-space: nowrap;
  }

  .trust-block a {
    color: var(--accent-light);
    text-decoration: none;
  }
  .trust-block a:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .trust-block { flex-direction: column; gap: var(--space-4); }
    .trust-block-icon { display: none; }
  }
</style>
