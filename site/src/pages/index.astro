---
import Layout from '../layouts/Layout.astro';
import GlassCard from '../components/GlassCard.astro';
import CTASection from '../components/CTASection.astro';
import Icon from '../components/Icon.astro';
import AppIcon from '../components/AppIcon.astro';
import ScreenshotFrame from '../components/ScreenshotFrame.astro';
---

<Layout
  title="BabyBlocks: Simple iOS Apps for a Calmer Life"
  description="BabyBlocks is a suite of simple, visual iOS apps designed to bring clarity and calm to everyday life. BudgetBaby is the flagship, now available on the App Store."
  canonical="/"
  theme="core"
>
  <!-- Hero -->
  <section class="hero section">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="label-chip">Now on the App Store</div>
          <h1>Know what's safe<br /><span class="text-gradient">to spend today.</span></h1>
          <p class="hero-sub">
            BudgetBaby gives you one clear number every day. It factors in your bills, your savings goals,
            and your remaining budget so you never have to guess. Set up in 3 minutes.
          </p>
          <div class="hero-actions">
            <a href="/budgetbaby" class="btn btn-primary btn-lg">
              Explore BudgetBaby
            </a>
            <a href="/budgetbaby/features" class="btn btn-secondary btn-lg">
              See how it works
            </a>
          </div>
          <p class="hero-note">Free to download · iOS 17+ · Premium from $7.99/mo</p>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <div class="phone-mockup glass">
            <div class="sts-mock">
              <div class="sts-label">Safe to Spend Today</div>
              <div class="sts-amount">$42<span class="sts-cents">.50</span></div>
              <div class="sts-bar">
                <div class="sts-bar-fill" style="width: 62%"></div>
              </div>
              <div class="sts-pools">
                <div class="sts-pool">
                  <Icon name="dollar-sign" size={14} />
                  <span>Cash</span>
                  <span class="sts-pool-val">$124</span>
                </div>
                <div class="sts-pool">
                  <Icon name="credit-card" size={14} />
                  <span>Debit</span>
                  <span class="sts-pool-val">$843</span>
                </div>
                <div class="sts-pool">
                  <Icon name="credit-card" size={14} />
                  <span>Credit</span>
                  <span class="sts-pool-val">$210</span>
                </div>
                <div class="sts-pool">
                  <Icon name="lock" size={14} />
                  <span>Savings</span>
                  <span class="sts-pool-val">$1,200</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <div class="trust-strip container">
    <span><Icon name="server" size={15} /> Local-first by default</span>
    <span><Icon name="wifi-off" size={15} /> No bank connections</span>
    <span><Icon name="cloud-upload" size={15} /> Optional encrypted backup</span>
    <span><Icon name="smartphone" size={15} /> Built for iOS 17+</span>
    <span><Icon name="message-circle" size={15} /> Human support</span>
  </div>

  <!-- Apps Grid -->
  <section class="apps-section section-sm">
    <div class="container">
      <div class="section-header centered">
        <span class="eyebrow">The Ecosystem</span>
        <h2>Apps built for real life</h2>
        <p>Each BabyBlocks app solves one problem well. No feature sprawl. No subscription bundles for things you don't need.</p>
      </div>

      <div class="apps-grid">
        <!-- BudgetBaby — Live -->
        <a href="/budgetbaby" class="app-card glass app-card--featured">
          <div class="app-card-header">
            <AppIcon app="budgetbaby" size={52} />
            <div class="app-status app-status--live">Available Now</div>
          </div>
          <h3>BudgetBaby</h3>
          <p>See where your money goes. Know what's safe to spend today. Plan without the stress.</p>
          <div class="app-meta">
            <span>iOS 17+</span>
            <span>·</span>
            <span>Free to start</span>
            <span>·</span>
            <span>Premium $7.99/mo</span>
          </div>
          <div class="app-cta">
            Explore BudgetBaby →
          </div>
        </a>

        <!-- PantryBaby — Coming Soon -->
        <div class="app-card glass app-card--soon">
          <div class="app-card-header">
            <AppIcon app="pantrybaby" size={52} />
            <div class="app-status app-status--soon">Coming Soon</div>
          </div>
          <h3>PantryBaby</h3>
          <p>Your grocery list and pantry memory. Track what you have, what's running low, and what you need. Without having to think about it.</p>
          <div class="app-meta">
            <span>In development</span>
          </div>
          <a href="/coming-soon/pantrybaby" class="app-cta-link">
            Get notified →
          </a>
        </div>

        <!-- Future -->
        <div class="app-card glass app-card--future">
          <div class="app-card-header">
            <div class="app-icon app-icon--future">
              <Icon name="box" size={28} />
            </div>
            <div class="app-status app-status--future">In Planning</div>
          </div>
          <h3>More coming</h3>
          <p>The ecosystem is expanding. Each new app will follow the same principle: one problem, solved simply.</p>
          <div class="app-meta">
            <span>Stay tuned</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshot Showcase -->
  <section class="screenshots-section section-sm">
    <div class="container">
      <div class="section-header centered">
        <span class="eyebrow">BudgetBaby</span>
        <h2>See it for yourself.</h2>
        <p>Three views. Everything you need to understand your money today.</p>
      </div>
      <div class="screenshots-grid">
        <ScreenshotFrame label="Safe to Spend" caption="Your number, right now">
          <div class="mock-screen mock-sts">
            <div class="ms-label">Safe to Spend Today</div>
            <div class="ms-amount green">$42<span>.50</span></div>
            <div class="ms-bar"><div class="ms-bar-fill" style="width:62%"></div></div>
            <div class="ms-row"><span class="ms-row-label">Remaining</span><span>$312.00</span></div>
            <div class="ms-row"><span class="ms-row-label">Bills due</span><span>$180.00</span></div>
            <div class="ms-row"><span class="ms-row-label">Savings</span><span>$90.00</span></div>
            <div class="ms-row"><span class="ms-row-label">Days left</span><span>5</span></div>
          </div>
        </ScreenshotFrame>

        <ScreenshotFrame label="Money Pools" caption="See where it lives">
          <div class="mock-screen mock-pools">
            <div class="ms-label">Money Pools</div>
            <div class="ms-pool-row">
              <div class="ms-pool-icon"><Icon name="dollar-sign" size={13} /></div>
              <div class="ms-pool-info"><span>Cash</span><span class="ms-val">$124</span></div>
            </div>
            <div class="ms-pool-row">
              <div class="ms-pool-icon"><Icon name="credit-card" size={13} /></div>
              <div class="ms-pool-info"><span>Debit</span><span class="ms-val">$843</span></div>
            </div>
            <div class="ms-pool-row">
              <div class="ms-pool-icon"><Icon name="credit-card" size={13} /></div>
              <div class="ms-pool-info"><span>Credit</span><span class="ms-val red">–$210</span></div>
            </div>
            <div class="ms-pool-row">
              <div class="ms-pool-icon"><Icon name="lock" size={13} /></div>
              <div class="ms-pool-info"><span>Savings</span><span class="ms-val">$1,200</span></div>
            </div>
          </div>
        </ScreenshotFrame>

        <ScreenshotFrame label="Insights" caption="Understand the pattern">
          <div class="mock-screen mock-insights">
            <div class="ms-label">This Month</div>
            <div class="ms-bar-chart">
              <div class="ms-chart-row">
                <span class="ms-chart-label">Groceries</span>
                <div class="ms-chart-bar" style="width:72%"></div>
              </div>
              <div class="ms-chart-row">
                <span class="ms-chart-label">Dining</span>
                <div class="ms-chart-bar" style="width:48%"></div>
              </div>
              <div class="ms-chart-row">
                <span class="ms-chart-label">Transport</span>
                <div class="ms-chart-bar" style="width:30%"></div>
              </div>
              <div class="ms-chart-row">
                <span class="ms-chart-label">Health</span>
                <div class="ms-chart-bar" style="width:20%"></div>
              </div>
            </div>
            <div class="ms-row ms-total"><span class="ms-row-label">Total spent</span><span>$642</span></div>
          </div>
        </ScreenshotFrame>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="philosophy section-sm">
    <div class="container-sm">
      <div class="section-header centered">
        <span class="eyebrow">Our Approach</span>
        <h2>Built on one principle</h2>
      </div>
      <div class="principles-grid">
        <GlassCard glow>
          <div class="principle">
            <div class="principle-icon">
              <Icon name="target" size={28} />
            </div>
            <h3>One problem at a time</h3>
            <p>Every app in the ecosystem tackles a single, well-defined problem. No sprawling all-in-one tools that do everything poorly.</p>
          </div>
        </GlassCard>
        <GlassCard glow>
          <div class="principle">
            <div class="principle-icon">
              <Icon name="eye" size={28} />
            </div>
            <h3>Clarity over cleverness</h3>
            <p>Design that shows you what you need to see, instantly. No dashboards full of charts you'll never read.</p>
          </div>
        </GlassCard>
        <GlassCard glow>
          <div class="principle">
            <div class="principle-icon">
              <Icon name="lock" size={28} />
            </div>
            <h3>Privacy by default</h3>
            <p>Your data lives on your device. Cloud features are optional and always opt-in. We don't sell your information.</p>
          </div>
        </GlassCard>
      </div>
    </div>
  </section>

  <CTASection
    heading="Start with BudgetBaby."
    subheading="The flagship app is live on the App Store. Know your Safe to Spend number today."
    primaryLabel="Download BudgetBaby"
    primaryHref="https://apps.apple.com/app/id6756576123"
    secondaryLabel="Learn more"
    secondaryHref="/budgetbaby"
  />
</Layout>

<style>
  /* Hero */
  .hero { padding-top: calc(var(--space-20) + var(--space-8)); padding-bottom: var(--space-16); }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: var(--space-16);
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .hero-content h1 {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
    line-height: var(--leading-tight);
    letter-spacing: -0.03em;
  }

  .hero-sub {
    font-size: clamp(var(--text-base), 2vw, var(--text-lg));
    color: var(--text-secondary);
    max-width: 48ch;
    line-height: var(--leading-relaxed);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero-note {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  /* Phone mockup */
  .phone-mockup {
    border-radius: var(--radius-2xl);
    padding: var(--space-6);
    background: var(--accent-dim);
    border-color: var(--accent-border);
    box-shadow: var(--glow-md), var(--shadow-xl);
  }

  .sts-mock { display: flex; flex-direction: column; gap: var(--space-4); }

  .sts-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .sts-amount {
    font-size: 3.2rem;
    font-weight: 800;
    color: var(--green);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .sts-cents { font-size: 1.8rem; opacity: 0.7; }

  .sts-bar {
    height: 6px;
    background: var(--glass-border);
    border-radius: 3px;
    overflow: hidden;
  }

  .sts-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-light));
    border-radius: 3px;
  }

  .sts-pools {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-2);
    border-top: 1px solid var(--glass-border);
  }

  .sts-pool {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .sts-pool svg { color: var(--text-muted); flex-shrink: 0; }

  .sts-pool-val {
    margin-left: auto;
    font-weight: var(--weight-semibold);
    color: var(--text-primary);
    font-size: var(--text-sm);
  }

  /* Apps Grid */
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .app-card {
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: all 0.2s ease;
  }

  .app-card:hover { transform: translateY(-3px); }

  .app-card--featured {
    border-color: var(--accent-border);
    background: var(--accent-dim);
  }

  .app-card--featured:hover {
    border-color: rgba(139, 92, 246, 0.35);
    box-shadow: var(--glow-md);
  }

  .app-card--soon, .app-card--future { opacity: 0.75; }

  .app-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .app-icon {
    width: 52px; height: 52px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .app-icon--budget { background: rgba(139, 92, 246, 0.15); color: var(--accent-light); }
  .app-icon--pantry { background: rgba(52, 211, 153, 0.12); color: var(--green); }
  .app-icon--future { background: rgba(255,255,255,0.05); color: var(--text-muted); }

  .app-status {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
    letter-spacing: 0.04em;
  }

  .app-status--live {
    background: rgba(52, 211, 153, 0.15);
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.25);
  }

  .app-status--soon {
    background: rgba(251, 191, 36, 0.12);
    color: var(--yellow);
    border: 1px solid rgba(251, 191, 36, 0.2);
  }

  .app-status--future {
    background: var(--glass-bg);
    color: var(--text-muted);
    border: 1px solid var(--glass-border);
  }

  .app-card h3 {
    font-size: var(--text-xl);
    color: var(--text-primary);
  }

  .app-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    flex: 1;
    line-height: var(--leading-relaxed);
  }

  .app-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: auto;
  }

  .app-cta {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--accent-light);
    margin-top: var(--space-2);
  }

  .app-cta-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text-muted);
    text-decoration: none;
    margin-top: var(--space-2);
    display: inline-block;
    transition: color 0.15s;
  }

  .app-cta-link:hover { color: var(--text-secondary); }

  /* Screenshots section */
  .screenshots-section .section-header { margin-bottom: var(--space-12); }

  /* Mock screen content styles */
  .mock-screen {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: 10px;
    line-height: 1.4;
    color: var(--text-secondary);
    height: 100%;
  }

  .ms-label {
    font-size: 8px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }

  .ms-amount {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .ms-amount.green { color: var(--green); }

  .ms-amount span { font-size: 18px; opacity: 0.7; }

  .ms-bar {
    height: 4px;
    background: var(--glass-border);
    border-radius: 2px;
    overflow: hidden;
    margin-block: 2px;
  }

  .ms-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-light));
    border-radius: 2px;
  }

  .ms-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    color: var(--text-secondary);
    padding: 2px 0;
    border-bottom: 1px solid var(--glass-border);
  }

  .ms-row-label { color: var(--text-muted); }
  .ms-total { margin-top: var(--space-2); border-bottom: none; font-weight: 600; }

  /* Pool mock */
  .ms-pool-row {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 0;
    border-bottom: 1px solid var(--glass-border);
    font-size: 10px;
  }

  .ms-pool-icon {
    width: 22px; height: 22px;
    border-radius: 6px;
    background: var(--glass-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-light);
    flex-shrink: 0;
  }

  .ms-pool-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex: 1;
  }

  .ms-val { font-weight: 600; color: var(--text-primary); }
  .ms-val.red { color: var(--red); }

  /* Bar chart mock */
  .ms-bar-chart {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
    margin-top: var(--space-1);
  }

  .ms-chart-row {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ms-chart-label {
    font-size: 8px;
    color: var(--text-muted);
    width: 44px;
    flex-shrink: 0;
  }

  .ms-chart-bar {
    height: 8px;
    background: linear-gradient(90deg, var(--accent), var(--accent-light));
    border-radius: 4px;
    opacity: 0.75;
  }

  /* Principles */
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .principle {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .principle-icon {
    color: var(--accent-light);
    margin-bottom: var(--space-1);
    line-height: 1;
  }

  .principle h3 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
  }

  .principle p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { order: -1; max-width: 320px; }
    .apps-grid { grid-template-columns: 1fr; }
    .principles-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { text-align: center; justify-content: center; }
  }
</style>
