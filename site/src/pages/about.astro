---
import Layout from '../layouts/Layout.astro';
import GlassCard from '../components/GlassCard.astro';
import CTASection from '../components/CTASection.astro';
import Icon from '../components/Icon.astro';
import AppIcon from '../components/AppIcon.astro';

const ecosystemApps = [
  {
    appIcon: 'budgetbaby' as const,
    iconColor: 'budget',
    name: 'BudgetBaby',
    status: 'live',
    statusLabel: 'Available Now',
    tagline: 'Know what\'s safe to spend today.',
    href: '/budgetbaby',
  },
  {
    appIcon: 'pantrybaby' as const,
    iconColor: 'pantry',
    name: 'PantryBaby',
    status: 'soon',
    statusLabel: 'Coming Soon',
    tagline: 'Your grocery list + pantry memory.',
    href: '/coming-soon/pantrybaby',
  },
  {
    appIcon: null,
    iconColor: 'future',
    name: 'More apps',
    status: 'future',
    statusLabel: 'In Planning',
    tagline: 'Each solving one problem, well.',
    href: null,
  },
];
---

<Layout
  title="About BabyBlocks"
  description="BabyBlocks is a suite of simple, visual iOS apps built by Intriguing Insight. Clarity, control, and calm. No unnecessary complexity."
  canonical="/about"
  theme="core"
>
  <!-- Hero -->
  <section class="about-hero section">
    <div class="container">
      <div class="about-hero-inner">
        <div class="about-hero-copy">
          <div class="label-chip">About</div>
          <h1>We make apps<br /><span class="text-gradient">that get out of your way.</span></h1>
          <p>
            BabyBlocks is a small ecosystem of iOS tools built on a straightforward idea:
            the best app is one that gives you exactly what you need and nothing more.
            No dashboards full of metrics you won't use. No features added just because the competition has them.
          </p>
          <p>
            Every BabyBlocks app is designed to solve one specific problem. Clearly, privately, and without fuss.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What BabyBlocks is -->
  <section class="what-section section-sm">
    <div class="container-sm">
      <GlassCard accent padding="lg">
        <div class="what-inner">
          <h2>What is BabyBlocks?</h2>
          <p>
            BabyBlocks is a suite of productivity and lifestyle iOS apps, each focused on a specific area of daily life.
            The apps share a visual language and philosophy but are designed to work independently.
            You don't need to use all of them to get value from any one of them.
          </p>
          <p>
            The suite is built and published by <strong>Intriguing Insight</strong>, a division of Intrigue MMC LLC,
            built on the belief that personal software should feel calm, not overwhelming.
          </p>
          <p>
            BudgetBaby, the flagship product, launched in December 2024 and is available on the iOS App Store.
            PantryBaby, a grocery and pantry management app, is in development and coming soon.
          </p>
        </div>
      </GlassCard>
    </div>
  </section>

  <!-- Why we built this -->
  <section class="why-section section-sm">
    <div class="container">
      <div class="section-header centered">
        <span class="eyebrow">Philosophy</span>
        <h2>Why we built this.</h2>
        <p>Three ideas that guide every decision we make.</p>
      </div>

      <div class="why-grid">
        <GlassCard glow>
          <div class="why-item">
            <div class="why-num">01</div>
            <h3>Clarity over complexity</h3>
            <p>
              The best financial apps we've used give you one clear number that answers the question you actually have.
              "Can I afford this right now?" Most apps don't answer that. BudgetBaby does. That's Safe to Spend.
            </p>
            <p>
              We apply the same thinking to every feature: if you have to learn something to use it,
              we haven't designed it well enough yet.
            </p>
          </div>
        </GlassCard>

        <GlassCard glow>
          <div class="why-item">
            <div class="why-num">02</div>
            <h3>Control, not automation</h3>
            <p>
              We deliberately chose not to connect BudgetBaby to your bank. Manual tracking has a meaningful advantage:
              you actually know what you spent, because you logged it.
            </p>
            <p>
              Automation can create a sense of control without the understanding that comes from it.
              We'd rather you be more aware of your money, not less.
            </p>
          </div>
        </GlassCard>

        <GlassCard glow>
          <div class="why-item">
            <div class="why-num">03</div>
            <h3>Privacy by default</h3>
            <p>
              Financial data is some of the most sensitive information a person has. BabyBlocks apps store
              your data on your device by default. Cloud features require explicit opt-in. We don't sell data.
              We don't use it for advertising.
            </p>
            <p>
              We make money from subscriptions. Not from selling your behavior to third parties.
            </p>
          </div>
        </GlassCard>
      </div>
    </div>
  </section>

  <!-- Ecosystem Map -->
  <section class="ecosystem-section section-sm">
    <div class="container">
      <div class="section-header centered">
        <span class="eyebrow">The Ecosystem</span>
        <h2>Where we are now, and where we're going.</h2>
      </div>

      <div class="ecosystem-grid">
        {ecosystemApps.map((app) => (
          <div class={`eco-card glass ${app.status === 'future' ? 'eco-card--future' : ''}`}>
            <div class="eco-card-top">
              {app.appIcon
                ? <AppIcon app={app.appIcon} size={44} />
                : <div class={`eco-icon eco-icon--${app.iconColor}`}><Icon name="box" size={26} /></div>
              }
              <span class={`eco-status eco-status--${app.status}`}>{app.statusLabel}</span>
            </div>
            <h3>{app.name}</h3>
            <p>{app.tagline}</p>
            {app.href && (
              <a href={app.href} class="eco-link">
                {app.status === 'live' ? 'Learn more →' : 'Get notified →'}
              </a>
            )}
          </div>
        ))}
      </div>

      <p class="ecosystem-note">
        Each app in the BabyBlocks ecosystem is built to stand alone. There's no requirement to use multiple apps.
        But if you do, they're designed to complement each other naturally.
      </p>
    </div>
  </section>

  <!-- Trust & Contact -->
  <section class="trust-section section-sm">
    <div class="container-sm">
      <div class="trust-grid">
        <GlassCard>
          <div class="trust-item">
            <div class="trust-icon"><Icon name="lock" size={24} /></div>
            <h3>Privacy first</h3>
            <p>Local data by default. Cloud features opt-in only. We don't sell your information or use it for advertising. Full details in our <a href="/budgetbaby/privacy">Privacy Policy</a>.</p>
          </div>
        </GlassCard>

        <GlassCard>
          <div class="trust-item">
            <div class="trust-icon"><Icon name="mail" size={24} /></div>
            <h3>Real support</h3>
            <p>Real humans read every support email. Reach us at <a href="mailto:support@babyblocks.io">support@babyblocks.io</a> and we'll respond within a couple of business days.</p>
          </div>
        </GlassCard>

        <GlassCard>
          <div class="trust-item">
            <div class="trust-icon"><Icon name="map-pin" size={24} /></div>
            <h3>Transparent roadmap</h3>
            <p>Feature requests are public and voteable at <a href="https://babyblocks.canny.io/feature-requests" target="_blank" rel="noopener noreferrer">babyblocks.canny.io</a>. We build what you actually ask for.</p>
          </div>
        </GlassCard>
      </div>
    </div>
  </section>

  <!-- Company -->
  <section class="company-section section-sm">
    <div class="container-sm">
      <GlassCard padding="lg">
        <div class="company-inner">
          <h2>About the company</h2>
          <p>
            BabyBlocks is built and published by <strong>Intriguing Insight</strong>,
            a division of <strong>Intrigue MMC LLC</strong>.
            Intriguing Insight is focused on building software that respects the people who use it.
          </p>
          <p>
            Our apps are premium products sold through the App Store with straightforward subscription pricing.
            We don't run ads, we don't mine data, and we don't have VC funding pressuring us to monetise
            in ways that conflict with our users' interests.
          </p>
          <p>
            If you have questions, feedback, or just want to say hi, email us at
            <a href="mailto:support@babyblocks.io">support@babyblocks.io</a>.
          </p>
        </div>
      </GlassCard>
    </div>
  </section>

  <CTASection
    heading="Start with BudgetBaby."
    subheading="The flagship app is available on the App Store now."
    primaryLabel="Download BudgetBaby"
    primaryHref="https://apps.apple.com/app/id6756576123"
    secondaryLabel="Explore features"
    secondaryHref="/budgetbaby/features"
  />
</Layout>

<style>
  .about-hero {
    padding-top: calc(var(--space-20) + var(--space-8));
  }

  .about-hero-inner {
    max-width: 720px;
  }

  .about-hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about-hero-copy h1 {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
    letter-spacing: -0.03em;
  }

  .about-hero-copy p {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 58ch;
  }

  /* What section */
  .what-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .what-inner h2 { font-size: var(--text-2xl); }

  .what-inner p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Why grid */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .why-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .why-num {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--accent-light);
    letter-spacing: 0.1em;
  }

  .why-item h3 { font-size: var(--text-xl); }

  .why-item p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Ecosystem */
  .ecosystem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }

  .eco-card {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .eco-card--future { opacity: 0.6; }

  .eco-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .eco-icon {
    width: 48px; height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .eco-icon--budget { background: rgba(139, 92, 246, 0.15); color: var(--accent-light); }
  .eco-icon--pantry { background: rgba(52, 211, 153, 0.12); color: var(--green); }
  .eco-icon--future { background: rgba(255,255,255,0.05); color: var(--text-muted); }

  .eco-status {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
  }

  .eco-status--live {
    background: rgba(52, 211, 153, 0.15);
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.25);
  }

  .eco-status--soon {
    background: rgba(251, 191, 36, 0.12);
    color: var(--yellow);
    border: 1px solid rgba(251, 191, 36, 0.2);
  }

  .eco-status--future {
    background: var(--glass-bg);
    color: var(--text-muted);
    border: 1px solid var(--glass-border);
  }

  .eco-card h3 { font-size: var(--text-xl); }

  .eco-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    flex: 1;
  }

  .eco-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--accent-light);
    text-decoration: none;
    transition: color 0.15s;
  }

  .eco-link:hover { color: var(--purple-300); }

  .ecosystem-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-align: center;
    max-width: 56ch;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  /* Trust */
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .trust-icon { color: var(--accent-light); line-height: 1; }
  .trust-item h3 { font-size: var(--text-lg); }

  .trust-item p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Company */
  .company-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .company-inner h2 { font-size: var(--text-2xl); }

  .company-inner p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 900px) {
    .why-grid, .ecosystem-grid, .trust-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .about-hero-copy h1 { font-size: var(--text-4xl); }
  }
</style>
